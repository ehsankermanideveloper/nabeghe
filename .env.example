# PostgreSQL — default dev port 5432
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=nabeghe_core

# Keep false once you rely on migrations; only true for quick local prototyping without migration:run
DATABASE_SYNC=false

# Connection pool (per worker when CLUSTER_ENABLED=true)
DATABASE_POOL_MAX=10
DATABASE_POOL_MIN=2
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=5000

PORT=3000
NODE_ENV=development

# fatal | error | warn | info | debug | trace | silent
# LOG_LEVEL=info

# Cluster (production): one process per CPU core
CLUSTER_ENABLED=false
# CLUSTER_ENABLED=true
# CLUSTER_WORKERS=0
# 0 = auto (number of CPU cores). Example: 4 workers → set CLUSTER_WORKERS=4
# Total Postgres connections ≈ CLUSTER_WORKERS × DATABASE_POOL_MAX

# Cache (memory | redis)
CACHE_ENABLED=true
CACHE_STORE=memory
CACHE_TTL_MS=60000
CACHE_PREFIX=nabeghe
# CACHE_STORE=redis
# CACHE_REDIS_URL=redis://127.0.0.1:6379

# Auth (session + OTP — SMS disabled in dev; fixed code below)
SESSION_SECRET=change-me-to-a-long-random-string-in-production
# With CLUSTER_ENABLED=true you must use Redis for sessions (shared across workers)
# SESSION_STORE=redis
# SESSION_REDIS_URL=redis://127.0.0.1:6379
# true only behind HTTPS (http://localhost prod needs false)
SESSION_COOKIE_SECURE=false
AUTH_OTP_CODE=252525
