<%
const ch = course.totalDuration ? Math.floor(course.totalDuration / 3600) : 0;
const cm = course.totalDuration ? Math.floor((course.totalDuration % 3600) / 60) : 0;
const durationText = ch > 0
  ? (ch + ' ' + t('label_hour') + (cm > 0 ? ' ' + t('label_and') + ' ' + cm + ' ' + t('label_minute') : ''))
  : (cm > 0 ? cm + ' ' + t('label_minute') : null);
%>
<div class="relative">
  <div class="relative z-10">
    <a href="<%= lp %>/courses/<%= course.slug %>" class="block">
      <% if (loc(course.thumbnail)) { %>
      <div class="relative rounded-3xl overflow-hidden aspect-video bg-secondary">
        <div data-skeleton class="absolute inset-0 animate-pulse bg-secondary rounded-3xl"></div>
        <img
          src="<%= loc(course.thumbnail) %>"
          data-img
          loading="lazy"
          style=""
          class="inset-0 w-full h-full object-cover"
          alt="<%= loc(course.title) %>"
        />
      </div>
      <% } else { %>
      <div class="w-full aspect-video rounded-3xl bg-secondary flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-16 h-16 text-muted/30">
          <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9A2.25 2.25 0 0 0 4.5 18.75Z" />
        </svg>
      </div>
      <% } %>
    </a>
    <% if (course.category) { %>
    <a href="<%= lp %>/courses?category=<%= course.category.slug %>"
      class="absolute <%= dir === 'ltr' ? 'left-3' : 'right-3' %> top-3 h-11 inline-flex items-center justify-center gap-1 bg-black/20 rounded-full text-white transition-all hover:opacity-80 px-4">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
        <path fill-rule="evenodd" d="M3 6a3 3 0 0 1 3-3h2.25a3 3 0 0 1 3 3v2.25a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6Zm9.75 0a3 3 0 0 1 3-3H18a3 3 0 0 1 3 3v2.25a3 3 0 0 1-3 3h-2.25a3 3 0 0 1-3-3V6ZM3 15.75a3 3 0 0 1 3-3h2.25a3 3 0 0 1 3 3V18a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3v-2.25Zm9.75 0a3 3 0 0 1 3-3H18a3 3 0 0 1 3 3V18a3 3 0 0 1-3 3h-2.25a3 3 0 0 1-3-3v-2.25Z" clip-rule="evenodd" />
      </svg>
      <span class="font-semibold text-sm"><%= loc(course.category.title) %></span>
    </a>
    <% } %>
  </div>

  <div class="bg-background rounded-b-3xl -mt-12 pt-12">
    <div class="bg-gradient-to-b from-background to-secondary rounded-b-3xl space-y-2 p-5 mx-5">
      <div class="flex items-center gap-2">
        <span class="block w-1 h-1 bg-success rounded-full"></span>
        <span class="font-bold text-xs text-success"><%= t('label_published') %></span>
      </div>
      <h2 class="font-bold text-sm">
        <a href="<%= lp %>/courses/<%= course.slug %>" class="line-clamp-1 text-foreground transition-colors hover:text-primary"><%= loc(course.title) %></a>
      </h2>
    </div>

    <div class="space-y-3 p-5">
      <div class="flex flex-wrap items-center gap-3">
        <div class="flex items-center gap-1 text-muted">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
            <path d="M7 3.5A1.5 1.5 0 0 1 8.5 2h3.879a1.5 1.5 0 0 1 1.06.44l3.122 3.12A1.5 1.5 0 0 1 17 6.622V12.5a1.5 1.5 0 0 1-1.5 1.5h-1v-3.379a3 3 0 0 0-.879-2.121L10.5 5.379A3 3 0 0 0 8.379 4.5H7v-1Z" />
            <path d="M4.5 6A1.5 1.5 0 0 0 3 7.5v9A1.5 1.5 0 0 0 4.5 18h7a1.5 1.5 0 0 0 1.5-1.5v-5.879a1.5 1.5 0 0 0-.44-1.06L9.44 6.439A1.5 1.5 0 0 0 8.378 6H4.5Z" />
          </svg>
          <span class="font-semibold text-xs"><%= course.totalEpisodes %> <%= t('label_episodes') %></span>
        </div>
        <% if (durationText) { %>
        <span class="block w-1 h-1 bg-muted-foreground rounded-full"></span>
        <div class="flex items-center gap-1 text-muted">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
            <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 0 0 0-1.5h-3.25V5Z" clip-rule="evenodd" />
          </svg>
          <span class="font-semibold text-xs"><%= durationText %></span>
        </div>
        <% } %>
      </div>

      <div class="flex items-center justify-between gap-5">
        <% if (course.instructor) { %>
        <div class="flex items-center gap-3">
          <div class="relative flex-shrink-0 w-10 h-10 rounded-full overflow-hidden bg-secondary border border-border">
            <% if (course.instructor.avatar) { %>
            <div data-skeleton class="absolute inset-0 animate-pulse bg-secondary rounded-full"></div>
            <img
              src="<%= course.instructor.avatar %>"
              data-img
              style="opacity:0;transition:opacity 0.3s ease;"
              class="absolute inset-0 w-full h-full object-cover"
              alt="<%= loc(course.instructor.displayName) %>"
            />
            <% } else { %>
            <div class="w-full h-full flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-muted">
                <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM3.751 20.105a8.25 8.25 0 0 1 16.498 0 .75.75 0 0 1-.437.695A18.683 18.683 0 0 1 12 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 0 1-.437-.695Z" clip-rule="evenodd" />
              </svg>
            </div>
            <% } %>
          </div>
          <div class="flex flex-col items-start space-y-1">
            <span class="line-clamp-1 font-semibold text-xs text-muted"><%= t('label_instructor_colon') %></span>
            <span class="line-clamp-1 font-bold text-xs text-foreground"><%= loc(course.instructor.displayName) || t('label_instructor') %></span>
          </div>
        </div>
        <% } else { %>
        <div></div>
        <% } %>

        <div class="flex flex-col items-end justify-center h-14">
          <% if (course.price === 0) { %>
          <div class="flex items-center gap-1">
            <span class="font-black text-xl text-success"><%= t('label_free_exclaim') %></span>
          </div>
          <% } else if (course.discountPrice !== null && course.discountPrice !== undefined) { %>
          <span class="line-through text-muted text-sm"><%= course.price.toLocaleString('fa-IR') %></span>
          <div class="flex items-center gap-1">
            <span class="font-black text-xl text-foreground"><%= course.discountPrice.toLocaleString('fa-IR') %></span>
            <span class="text-xs text-muted"><%= t('label_currency') %></span>
          </div>
          <% } else { %>
          <div class="flex items-center gap-1">
            <span class="font-black text-xl text-foreground"><%= course.price.toLocaleString('fa-IR') %></span>
            <span class="text-xs text-muted"><%= t('label_currency') %></span>
          </div>
          <% } %>
        </div>
      </div>

      <div class="flex gap-3 mt-3">
        <a href="<%= lp %>/courses/<%= course.slug %>"
          class="w-full h-11 inline-flex items-center justify-center gap-1 bg-primary rounded-full text-primary-foreground transition-all hover:opacity-80 px-4">
          <span class="line-clamp-1 font-semibold text-sm"><%= t('btn_view_course') %></span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
            <path fill-rule="evenodd" d="M14.78 14.78a.75.75 0 0 1-1.06 0L6.5 7.56v5.69a.75.75 0 0 1-1.5 0v-7.5A.75.75 0 0 1 5.75 5h7.5a.75.75 0 0 1 0 1.5H7.56l7.22 7.22a.75.75 0 0 1 0 1.06Z" clip-rule="evenodd" />
          </svg>
        </a>
        <button type="button"
          class="flex-shrink-0 w-11 h-11 inline-flex items-center justify-center bg-secondary rounded-full transition-colors hover:text-red-500 <%= isWishlisted ? 'text-red-500' : 'text-muted' %>"
          onclick="toggleWishlistCard('<%= course.slug %>', this)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
            <path d="m9.653 16.915-.005-.003-.019-.01a20.759 20.759 0 0 1-1.162-.682 22.045 22.045 0 0 1-2.582-1.9C4.045 12.733 2 10.352 2 7.5a4.5 4.5 0 0 1 8-2.828A4.5 4.5 0 0 1 18 7.5c0 2.852-2.044 5.233-3.885 6.82a22.049 22.049 0 0 1-3.744 2.582l-.019.01-.005.003h-.002a.739.739 0 0 1-.69.001l-.002-.001Z" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>
