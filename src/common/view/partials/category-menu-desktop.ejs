<!-- categories (desktop) — server-side rendered -->
<div class="relative" x-data="{ open: false }" x-on:click.outside="open = false">
  <button
    type="button"
    class="inline-flex items-center gap-1 text-muted transition-colors hover:text-foreground"
    x-bind:class="open ? 'text-foreground' : ''"
    x-on:click="open = !open"
  >
    <span class="font-semibold text-sm">دسته بندی آمـــوزشها</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
      class="w-5 h-5 transition-transform"
      x-bind:class="open ? 'rotate-180' : ''"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
    </svg>
  </button>

  <div
    class="absolute right-0 top-full pt-3 z-30"
    x-show="open"
    x-transition
    x-cloak
    style="display: none"
  >
    <div class="w-[520px] bg-background border border-border rounded-2xl shadow-2xl shadow-black/5 p-4">

      <a
        href="/courses"
        class="flex items-center gap-2 w-full px-2 py-2 mb-3 rounded-xl text-primary font-bold text-sm hover:bg-secondary transition-colors"
        x-on:click="open = false"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 shrink-0">
          <path fill-rule="evenodd" d="M3 6a3 3 0 0 1 3-3h2.25a3 3 0 0 1 3 3v2.25a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6Zm9.75 0a3 3 0 0 1 3-3H18a3 3 0 0 1 3 3v2.25a3 3 0 0 1-3 3h-2.25a3 3 0 0 1-3-3V6ZM3 15.75a3 3 0 0 1 3-3h2.25a3 3 0 0 1 3 3V18a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3v-2.25Zm9.75 0a3 3 0 0 1 3-3H18a3 3 0 0 1 3 3V18a3 3 0 0 1-3 3h-2.25a3 3 0 0 1-3-3v-2.25Z" clip-rule="evenodd" />
        </svg>
        همه دسته‌بندی‌ها
      </a>

      <div class="h-px bg-border mb-3"></div>

      <% if (typeof menuCategories !== 'undefined' && menuCategories.length > 0) { %>
      <div class="grid grid-cols-2 gap-x-4 gap-y-4">
        <% menuCategories.forEach(function(item) { %>
        <div>
          <a
            href="<%= item.href %>"
            class="flex items-center gap-1.5 font-bold text-xs text-foreground hover:text-primary transition-colors mb-1.5"
            x-on:click="open = false"
          >
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-primary shrink-0"></span>
            <%= item.title %>
          </a>
          <% if (item.children && item.children.length > 0) { %>
          <ul class="space-y-1 pr-3">
            <% item.children.forEach(function(child) { %>
            <li>
              <a
                href="<%= child.href %>"
                class="flex items-center gap-1.5 text-muted text-xs font-medium hover:text-primary transition-colors py-0.5"
                x-on:click="open = false"
              >
                <span class="inline-block w-1 h-1 rounded-full bg-border shrink-0"></span>
                <%= child.title %>
              </a>
            </li>
            <% }) %>
          </ul>
          <% } %>
        </div>
        <% }) %>
      </div>
      <% } %>

    </div>
  </div>
</div>
