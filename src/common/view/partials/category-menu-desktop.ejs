<!-- categories (desktop) — loaded via /api/categories/menu -->
<div class="relative" x-data="categoryMenu()">
  <button
    type="button"
    class="inline-flex items-center gap-1 text-muted transition-colors hover:text-foreground"
    x-bind:class="open ? 'text-foreground' : ''"
    x-on:click="toggleOpen()"
    aria-haspopup="true"
    x-bind:aria-expanded="open"
  >
    <span class="font-semibold text-sm">دسته بندی آمـــوزشها</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
      class="w-5 h-5 transition-transform"
      x-bind:class="open ? 'rotate-180' : ''"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
    </svg>
  </button>

  <div
    class="absolute right-0 top-full pt-3 z-30"
    x-show="open"
    x-transition
    x-on:click.outside="closeOpen()"
    x-cloak
    style="display: none"
  >
    <div
      x-show="loading"
      class="flex flex-col w-56 min-h-[120px] bg-background border border-border shadow-2xl shadow-black/5 p-3 rounded-xl"
    >
      <span class="text-sm text-muted font-semibold">در حال بارگذاری...</span>
    </div>

    <div
      x-show="error && !loading"
      class="flex flex-col w-56 bg-background border border-border shadow-2xl shadow-black/5 p-3 rounded-xl"
    >
      <span class="text-sm text-error font-semibold">خطا در بارگذاری دسته‌ها</span>
    </div>

    <ul
      x-show="!loading && !error"
      class="flex flex-col relative w-56 min-h-[200px] bg-background border border-border shadow-2xl shadow-black/5 rounded-xl overflow-visible"
    >
      <template x-for="item in items" :key="item.id">
        <li class="group relative" x-show="hasChildren(item)">
          <a
            :href="item.href"
            class="flex items-center relative text-foreground transition-colors hover:text-primary p-3 rounded-t-xl"
          >
            <span class="font-semibold text-sm" x-text="item.title"></span>
            <span class="absolute left-3">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                class="w-5 h-5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15.75 19.5 8.25 12l7.5-7.5"
                />
              </svg>
            </span>
          </a>
          <ul
            class="absolute -top-px -bottom-px right-full flex flex-wrap flex-col w-96 bg-background border border-border shadow-2xl shadow-black/5 space-y-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible px-3 pt-8 pb-3 rounded-xl pointer-events-none group-hover:pointer-events-auto"
          >
            <li class="absolute top-2 pointer-events-none">
              <span class="font-bold text-sm text-muted" x-text="item.title"></span>
            </li>
            <template x-for="child in item.children" :key="child.id">
              <li class="w-1/2">
                <a
                  :href="child.href"
                  class="flex items-center gap-2 text-muted before:content-[''] before:inline-block before:w-1 before:h-1 before:bg-border before:rounded-full transition-colors hover:text-primary hover:before:bg-primary"
                >
                  <span class="font-semibold text-sm" x-text="child.title"></span>
                </a>
              </li>
            </template>
          </ul>
        </li>
        <li x-show="!hasChildren(item)">
          <a
            :href="item.href"
            class="flex items-center relative text-foreground transition-colors hover:text-primary p-3"
          >
            <span class="font-semibold text-sm" x-text="item.title"></span>
          </a>
        </li>
      </template>
    </ul>
  </div>
</div>
