                        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                        <!-- user:dropdown -->
                        <div class="relative hidden sm:block" x-data="{ isOpen: false }">
                            <button
                                type="button"
                                class="inline-flex items-center justify-center sm:gap-3 gap-0"
