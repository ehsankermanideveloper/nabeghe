                                aria-label="منوی حساب کاربری">
                                <span
                                    class="inline-flex items-center justify-center w-10 h-10 sm:w-9 sm:h-9 bg-secondary rounded-full text-foreground">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                        stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                            d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                                    </svg>
                                </span>
                                <span class="hidden sm:flex flex-col items-start text-xs space-y-1">
                                    <span class="font-semibold text-foreground max-w-[8rem] truncate"><%= currentUser.displayLabel %></span>
                                    <span class="font-semibold text-muted">خوش آمـــدید</span>
                                </span>
                                <span class="hidden sm:inline text-foreground transition-transform"
                                    x-bind:class="isOpen ? 'rotate-180' : ''">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                        stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                            d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                                    </svg>
                                </span>
                            </button>
                            <div class="absolute top-full end-0 pt-3 z-40" x-show="isOpen"
                                x-on:click.outside="isOpen = false">
                                <div
                                    class="w-56 bg-background border border-border rounded-xl shadow-2xl shadow-black/5 p-3">
                                    <a href="/profile"
                                        class="flex items-center gap-2 w-full text-foreground transition-colors hover:text-primary px-3 py-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                            stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
                                        </svg>
                                        <span class="font-semibold text-xs">مشاهده پروفایل</span>
                                    </a>
                                    <a href="/profile/courses"
                                        class="flex items-center gap-2 w-full text-foreground transition-colors hover:text-primary px-3 py-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                            stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
                                        </svg>
                                        <span class="font-semibold text-xs">دروه های من</span>
                                    </a>
                                    <a href="/profile/comments"
                                        class="flex items-center gap-2 w-full text-foreground transition-colors hover:text-primary px-3 py-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                            stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
                                        </svg>
                                        <span class="font-semibold text-xs">پرسش و دیدگاه ها</span>
                                    </a>
                                    <form action="/auth/logout" method="post">
                                        <% if (typeof csrfToken !== 'undefined') { %>
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                        <% } %>
                                        <button type="submit"
                                            class="flex items-center gap-2 w-full text-red-500 transition-colors hover:text-red-700 px-3 py-2">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                                stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                    d="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15m-3 0-3-3m0 0 3-3m-3 3H15" />
                                            </svg>
                                            <span class="font-semibold text-xs">خروج از حساب</span>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                        <!-- end user:dropdown -->
                        <% } else { %>
                        <a href="/auth/login"
                            class="inline-flex shrink-0 items-center justify-center w-10 h-10 sm:w-auto sm:h-10 sm:gap-1 sm:px-4 bg-primary rounded-full text-primary-foreground transition-all hover:opacity-80"
                            aria-label="ورود / حساب کاربری">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                                class="w-5 h-5 sm:w-6 sm:h-6">
                                <path fill-rule="evenodd"
                                    d="M7.5 3.75A1.5 1.5 0 0 0 6 5.25v13.5a1.5 1.5 0 0 0 1.5 1.5h6a1.5 1.5 0 0 0 1.5-1.5V15a.75.75 0 0 1 1.5 0v3.75a3 3 0 0 1-3 3h-6a3 3 0 0 1-3-3V5.25a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3V9A.75.75 0 0 1 15 9V5.25a1.5 1.5 0 0 0-1.5-1.5h-6Zm5.03 4.72a.75.75 0 0 1 0 1.06l-1.72 1.72h10.94a.75.75 0 0 1 0 1.5H10.81l1.72 1.72a.75.75 0 1 1-1.06 1.06l-3-3a.75.75 0 0 1 0-1.06l3-3a.75.75 0 0 1 1.06 0Z"
                                    clip-rule="evenodd" />
                            </svg>
                            <span class="hidden sm:inline font-semibold text-sm whitespace-nowrap">حساب کاربری</span>
                        </a>
                        <% } %>

                    </div>
                </div>

                        <!-- searchBox -->
                <div x-cloak class="absolute inset-x-4 hidden lg:flex flex-col h-full bg-background transition-all z-50"
                    x-bind:class="openSearchBox ? 'top-0' : '-top-full'"
                    x-data="{
                        q: '',
                        results: { courses: [], articles: [] },
                        loading: false,
                        showDropdown: false,
                        timer: null,
                        async doSearch() {
                            const val = this.q.trim();
                            if (!val || val.length < 2) { this.results = { courses: [], articles: [] }; this.showDropdown = false; return; }
                            this.loading = true;
                            try {
                                const res = await fetch('/api/search?q=' + encodeURIComponent(val));
                                this.results = await res.json();
                                this.showDropdown = this.results.courses.length > 0 || this.results.articles.length > 0;
                            } catch(e) {}
                            this.loading = false;
                        },
                        goSearch() {
                            if (this.q.trim()) window.location.href = '/search?q=' + encodeURIComponent(this.q.trim());
                        },
                        close() { this.showDropdown = false; openSearchBox = false; this.q = ''; this.results = { courses: [], articles: [] }; }
                    }"
                    x-on:keydown.escape.window="close()">
                    <form class="h-full" x-on:submit.prevent="goSearch()">
                        <div class="flex items-center h-full relative">
                            <input type="text"
                                x-model="q"
                                x-on:input.debounce.350ms="doSearch()"
                                x-on:focus="if(results.courses.length||results.articles.length) showDropdown=true"
                                x-ref="searchInput"
                                x-effect="if(openSearchBox) $nextTick(()=>$refs.searchInput.focus())"
                                class="form-input w-full !ring-0 !ring-offset-0 bg-background border-0 focus:border-0 text-foreground"
                                placeholder="نام دوره، مقاله یا دسته‌بندی را وارد کنید..." />

                            <!-- loading spinner -->
                            <span x-show="loading" class="absolute left-12 text-muted animate-spin">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="w-4 h-4">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                                </svg>
                            </span>

                            <button type="button"
                                class="absolute left-0 inline-flex items-center justify-center w-9 h-9 bg-secondary rounded-full text-muted transition-colors hover:text-red-500"
                                x-on:click="close()">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                                    stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                                </svg>
                            </button>
                        </div>
                    </form>

                    <!-- live results dropdown -->
                    <div x-show="showDropdown" x-on:click.outside="showDropdown=false"
                        class="absolute top-full right-0 left-0 bg-background border border-border rounded-2xl shadow-2xl shadow-black/10 overflow-hidden mt-1 max-h-[70vh] overflow-y-auto">

                        <!-- courses -->
                        <template x-if="results.courses.length > 0">
                            <div>
                                <div class="flex items-center gap-2 px-4 py-2.5 border-b border-border bg-secondary/50">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-primary">
                                        <path d="M10.75 16.82A7.462 7.462 0 0 1 15 15.5c.71 0 1.396.098 2.046.282A.75.75 0 0 0 18 15.06v-11a.75.75 0 0 0-.546-.721A9.006 9.006 0 0 0 15 3a8.963 8.963 0 0 0-4.25 1.065V16.82ZM9.25 4.065A8.963 8.963 0 0 0 5 3c-.85 0-1.673.118-2.454.339A.75.75 0 0 0 2 4.06v11a.75.75 0 0 0 .954.721A7.506 7.506 0 0 1 5 15.5c1.579 0 3.042.487 4.25 1.32V4.065Z" />
                                    </svg>
                                    <span class="text-xs font-bold text-foreground">دوره‌های آموزشی</span>
                                </div>
                                <template x-for="course in results.courses" :key="course.slug">
                                    <a :href="'/courses/' + course.slug"
                                        class="flex items-center gap-3 px-4 py-3 hover:bg-secondary/60 transition-colors border-b border-border/50 last:border-0">
                                        <div class="w-12 h-9 rounded-lg overflow-hidden bg-secondary shrink-0">
                                            <img x-show="course.thumbnail" :src="course.thumbnail" :alt="course.title" class="w-full h-full object-cover" />
                                            <div x-show="!course.thumbnail" class="w-full h-full flex items-center justify-center text-muted/40">
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9A2.25 2.25 0 0 0 4.5 18.75Z" /></svg>
                                            </div>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-semibold text-foreground truncate" x-text="course.title"></p>
                                            <p x-show="course.category" class="text-xs text-muted" x-text="course.category?.title"></p>
                                        </div>
                                        <span class="shrink-0 text-xs font-bold" :class="course.price === 0 ? 'text-success' : 'text-foreground'"
                                            x-text="course.price === 0 ? 'رایگان' : ((course.discountPrice ?? course.price).toLocaleString('fa-IR') + ' تومان')">
                                        </span>
                                    </a>
                                </template>
                            </div>
                        </template>

                        <!-- articles -->
                        <template x-if="results.articles.length > 0">
                            <div>
                                <div class="flex items-center gap-2 px-4 py-2.5 border-b border-border bg-secondary/50">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 text-primary">
                                        <path fill-rule="evenodd" d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 4.75Zm0 10.5a.75.75 0 0 1 .75-.75h7.5a.75.75 0 0 1 0 1.5h-7.5a.75.75 0 0 1-.75-.75ZM2 10a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 10Z" clip-rule="evenodd" />
                                    </svg>
                                    <span class="text-xs font-bold text-foreground">مقالات</span>
                                </div>
                                <template x-for="article in results.articles" :key="article.slug">
                                    <a :href="'/blog/' + article.slug"
                                        class="flex items-center gap-3 px-4 py-3 hover:bg-secondary/60 transition-colors border-b border-border/50 last:border-0">
                                        <div class="w-12 h-9 rounded-lg overflow-hidden bg-secondary shrink-0">
                                            <img x-show="article.thumbnail" :src="article.thumbnail" :alt="article.title" class="w-full h-full object-cover" />
                                            <div x-show="!article.thumbnail" class="w-full h-full flex items-center justify-center text-muted/40">
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6v-3Z" /></svg>
                                            </div>
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-semibold text-foreground truncate" x-text="article.title"></p>
                                            <p x-show="article.category" class="text-xs text-muted" x-text="article.category?.title"></p>
                                        </div>
                                        <span x-show="article.readTime" class="shrink-0 text-xs text-muted" x-text="article.readTime + ' دقیقه'"></span>
                                    </a>
                                </template>
                            </div>
                        </template>

                        <!-- see all results -->
                        <div class="px-4 py-3 border-t border-border bg-secondary/30">
                            <a :href="'/search?q=' + encodeURIComponent(q)"
                                class="flex items-center justify-center gap-2 w-full h-9 rounded-xl bg-primary text-primary-foreground text-sm font-semibold hover:opacity-80 transition-opacity">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                                    <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd" />
                                </svg>
                                <span>مشاهده همه نتایج</span>
                            </a>
                        </div>
                    </div>
                </div>
                <!-- end searchBox -->
            </div>
            <!-- end container -->

            <!-- offcanvas -->
            <div x-cloak>
                <!-- offcanvas:box -->
                <div class="fixed inset-y-0 right-0 xs:w-80 w-72 h-screen bg-background rounded-l-2xl overflow-y-auto transition-transform z-50"
                    x-bind:class="offcanvasOpen ? '!translate-x-0' : 'translate-x-full'">
                    <!-- offcanvas:header -->
                    <div class="flex items-center justify-between gap-x-4 sticky top-0 bg-background p-4 z-10">
                        <a href="/" class="inline-flex items-center gap-2 text-primary">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                                class="w-6 h-6">
                                <path
                                    d="M12 .75a8.25 8.25 0 0 0-4.135 15.39c.686.398 1.115 1.008 1.134 1.623a.75.75 0 0 0 .577.706c.352.083.71.148 1.074.195.323.041.6-.218.6-.544v-4.661a6.714 6.714 0 0 1-.937-.171.75.75 0 1 1 .374-1.453 5.261 5.261 0 0 0 2.626 0 .75.75 0 1 1 .374 1.452 6.712 6.712 0 0 1-.937.172v4.66c0 .327.277.586.6.545.364-.047.722-.112 1.074-.195a.75.75 0 0 0 .577-.706c.02-.615.448-1.225 1.134-1.623A8.25 8.25 0 0 0 12 .75Z" />
                                <path fill-rule="evenodd"
                                    d="M9.013 19.9a.75.75 0 0 1 .877-.597 11.319 11.319 0 0 0 4.22 0 .75.75 0 1 1 .28 1.473 12.819 12.819 0 0 1-4.78 0 .75.75 0 0 1-.597-.876ZM9.754 22.344a.75.75 0 0 1 .824-.668 13.682 13.682 0 0 0 2.844 0 .75.75 0 1 1 .156 1.492 15.156 15.156 0 0 1-3.156 0 .75.75 0 0 1-.668-.824Z"
                                    clip-rule="evenodd" />
                            </svg>
                            <span class="flex flex-col items-start">
                                <span class="font-semibold text-sm text-muted">آکادمی</span>
                                <span class="font-black text-xl">لیان امیری</span>
                            </span>
                        </a>

                        <!-- offcanvas:close-button -->
                        <button x-on:click="offcanvasOpen = false"
                            class="text-foreground focus:outline-none hover:text-red-500">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5"
                                stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                        </button><!-- end offcanvas:close-button -->
                    </div><!-- end offcanvas header -->

                    <!-- offcanvas:content -->
                    <div class="space-y-5 p-4">
                        <form action="/search" method="get">
                            <div class="flex items-center relative">
                                <input type="text" name="q"
                                    class="form-input w-full h-10 !ring-0 !ring-offset-0 bg-secondary border border-border focus:border-border rounded-xl text-sm text-foreground pr-10"
                                    placeholder="دنبال چی میگردی؟" />
                                <button type="submit" class="absolute right-3 text-muted hover:text-primary transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                                        class="w-5 h-5">
                                        <path fill-rule="evenodd"
                                            d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z"
                                            clip-rule="evenodd"></path>
                                    </svg>
                                </button>
                            </div>
                        </form>
                        <div class="h-px bg-border"></div>
                        <label class="relative w-full flex items-center justify-between cursor-pointer">
                            <span class="font-bold text-sm text-foreground">تم تاریک</span>
                            <input type="checkbox" class="sr-only peer" id="dark-mode-checkbox" />
                            <div
                                class="w-11 h-5 relative bg-background border-2 border-border peer-focus:outline-none rounded-full peer peer-checked:after:left-[26px] peer-checked:after:bg-background after:content-[''] after:absolute after:left-0.5 after:top-0.5 after:bg-border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-primary peer-checked:border-primary">
                            </div>
                        </label>
                        <div class="h-px bg-border"></div>

                        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                        <!-- offcanvas:user -->
                        <div class="flex items-center gap-3 py-1">
                            <span class="inline-flex items-center justify-center w-10 h-10 bg-secondary rounded-full text-foreground flex-shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                                </svg>
                            </span>
                            <div class="flex flex-col min-w-0">
                                <span class="font-semibold text-sm text-foreground truncate"><%= currentUser.displayLabel %></span>
                                <span class="font-semibold text-xs text-muted">خوش آمدید</span>
                            </div>
                        </div>
                        <ul class="flex flex-col space-y-1">
                            <li>
                                <a href="/profile" class="w-full flex items-center gap-x-2 relative text-muted transition-all hover:text-foreground py-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" /></svg>
                                    <span class="font-semibold text-xs">مشاهده پروفایل</span>
                                </a>
                            </li>
                            <li>
                                <a href="/profile/courses" class="w-full flex items-center gap-x-2 relative text-muted transition-all hover:text-foreground py-2">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>
                                    <span class="font-semibold text-xs">دروه های من</span>
                                </a>
                            </li>
                            <li>
                                <form action="/auth/logout" method="post">
                                    <% if (typeof csrfToken !== 'undefined') { %>
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                                    <% } %>
                                    <button type="submit" class="w-full flex items-center gap-x-2 text-red-500 transition-all hover:text-red-700 py-2">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15m-3 0-3-3m0 0 3-3m-3 3H15" /></svg>
                                        <span class="font-semibold text-xs">خروج از حساب</span>
                                    </button>
                                </form>
                            </li>
                        </ul>
                        <div class="h-px bg-border"></div>
                        <% } %>

                        <ul class="flex flex-col space-y-1">
                                                        <%- include('view/partials/category-menu-mobile') %>
                        </ul>
                    </div><!-- end offcanvas:content -->
                </div><!-- end offcanvas:box -->

                <!-- offcanvas:overlay -->
                <div class="fixed inset-0 h-screen bg-secondary/80 cursor-pointer transition-all duration-1000 z-40"
                    x-bind:class="offcanvasOpen ? 'opacity-100 visible' : 'opacity-0 invisible'"
                    x-on:click="offcanvasOpen = false">
                </div><!-- end offcanvas:overlay -->
            </div><!-- end offcanvas -->
        </header>
        <!-- end header -->
