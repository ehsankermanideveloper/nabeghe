<!-- user:info -->
<div class="flex items-center gap-5 mb-5">
  <div class="flex items-center gap-3">
    <div class="flex-shrink-0 w-10 h-10 rounded-full overflow-hidden bg-primary/10 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-primary">
        <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM3.751 20.105a8.25 8.25 0 0 1 16.498 0 .75.75 0 0 1-.437.695A18.683 18.683 0 0 1 12 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 0 1-.437-.695Z" clip-rule="evenodd" />
      </svg>
    </div>
    <div class="flex flex-col items-start space-y-1">
      <span class="text-xs text-muted">خوش آمدید</span>
      <span class="line-clamp-1 font-semibold text-sm text-foreground cursor-default"><%= user.displayName || 'کاربر گرامی' %></span>
    </div>
  </div>
</div>
<!-- end user:info -->

<!-- user:menus -->
<ul class="flex flex-col space-y-3 bg-secondary rounded-2xl p-5">
  <li>
    <a href="/profile"
      class="w-full h-11 inline-flex items-center text-right gap-3 <%= activeRoute === 'dashboard' ? 'bg-primary rounded-full text-primary-foreground' : 'bg-background rounded-full text-muted transition-colors hover:bg-primary hover:text-primary-foreground' %> px-4">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
        <path fill-rule="evenodd" d="M1.5 7.125c0-1.036.84-1.875 1.875-1.875h6c1.036 0 1.875.84 1.875 1.875v3.75c0 1.036-.84 1.875-1.875 1.875h-6A1.875 1.875 0 0 1 1.5 10.875v-3.75Zm12 1.5c0-1.036.84-1.875 1.875-1.875h5.25c1.035 0 1.875.84 1.875 1.875v8.25c0 1.035-.84 1.875-1.875 1.875h-5.25a1.875 1.875 0 0 1-1.875-1.875v-8.25ZM3 16.125c0-1.036.84-1.875 1.875-1.875h5.25c1.036 0 1.875.84 1.875 1.875v2.25c0 1.035-.84 1.875-1.875 1.875h-5.25A1.875 1.875 0 0 1 3 18.375v-2.25Z" clip-rule="evenodd" />
      </svg>
      <span class="font-semibold text-xs">پیشخوان</span>
    </a>
  </li>
  <li>
    <a href="/profile/courses"
      class="w-full h-11 inline-flex items-center text-right gap-3 <%= activeRoute === 'courses' ? 'bg-primary rounded-full text-primary-foreground' : 'bg-background rounded-full text-muted transition-colors hover:bg-primary hover:text-primary-foreground' %> px-4">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
      </svg>
      <span class="font-semibold text-xs">دوره ها</span>
    </a>
  </li>
  <li>
    <a href="/profile/wishlist"
      class="w-full h-11 inline-flex items-center text-right gap-3 <%= activeRoute === 'wishlist' ? 'bg-primary rounded-full text-primary-foreground' : 'bg-background rounded-full text-muted transition-colors hover:bg-primary hover:text-primary-foreground' %> px-4">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
      </svg>
      <span class="font-semibold text-xs">علاقمندی ها</span>
    </a>
  </li>
  <li>
    <a href="/profile/comments"
      class="w-full h-11 inline-flex items-center text-right gap-3 <%= activeRoute === 'comments' ? 'bg-primary rounded-full text-primary-foreground' : 'bg-background rounded-full text-muted transition-colors hover:bg-primary hover:text-primary-foreground' %> px-4">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 0 1-.825-.242m9.345-8.334a2.126 2.126 0 0 0-.476-.095 48.64 48.64 0 0 0-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0 0 11.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
      </svg>
      <span class="font-semibold text-xs">دیدگاه و پرسشهای شما</span>
    </a>
  </li>
  <li>
    <a href="/profile/edit"
      class="w-full h-11 inline-flex items-center text-right gap-3 <%= activeRoute === 'edit' ? 'bg-primary rounded-full text-primary-foreground' : 'bg-background rounded-full text-muted transition-colors hover:bg-primary hover:text-primary-foreground' %> px-4">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125" />
      </svg>
      <span class="font-semibold text-xs">ویرایش پروفایل</span>
    </a>
  </li>
</ul>
<!-- end user:menus -->
