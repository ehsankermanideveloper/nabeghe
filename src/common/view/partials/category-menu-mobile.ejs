<!-- categories (mobile offcanvas) -->
<li x-data="categoryMenu()" class="w-full">
  <button
    type="button"
    class="w-full flex items-center gap-x-2 relative transition-all hover:text-foreground py-2"
    x-bind:class="open ? 'text-foreground' : 'text-muted'"
    x-on:click="toggleOpen()"
    aria-haspopup="true"
    x-bind:aria-expanded="open"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
      <path
        fill-rule="evenodd"
        d="M3 9a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 9Zm0 6.75a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75a.75.75 0 0 1-.75-.75Z"
        clip-rule="evenodd"
      ></path>
    </svg>
    <span class="font-semibold text-xs">دسته بندی آموزشها</span>
    <span class="absolute left-3 transition-transform" x-bind:class="open ? 'rotate-180' : ''">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="w-5 h-5"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
      </svg>
    </span>
  </button>

  <ul
    class="flex flex-col relative before:content-[''] before:absolute before:inset-y-3 before:right-3 before:w-px before:bg-zinc-200 dark:before:bg-zinc-900 py-3 pr-5"
    x-show="open"
    x-transition
    x-cloak
    style="display: none"
  >
    <li x-show="loading" class="py-2 px-3 text-xs text-muted">در حال بارگذاری...</li>
    <li x-show="error && !loading" class="py-2 px-3 text-xs text-error">خطا در بارگذاری</li>

    <template x-for="item in items" :key="item.id">
      <li x-data="{ openChild: false }" x-show="!loading && !error && hasChildren(item)">
        <button
          type="button"
          class="w-full flex items-center gap-x-2 bg-transparent rounded-xl text-zinc-400 transition-all group/nav-item hover:text-black dark:hover:text-white py-2 px-3"
          x-on:click="openChild = !openChild"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
            class="w-4 h-4"
            x-bind:class="openChild ? '-rotate-45' : ''"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"></path>
          </svg>
          <span class="font-medium text-xs" x-text="item.title"></span>
        </button>
        <ul
          class="flex flex-col relative before:content-[''] before:absolute before:inset-y-3 before:right-3 before:w-px before:bg-zinc-200 dark:before:bg-zinc-900 py-3 pr-5"
          x-show="openChild"
          x-transition
        >
          <template x-for="child in item.children" :key="child.id">
            <li>
              <a
                :href="child.href"
                class="w-full flex items-center gap-x-2 bg-transparent rounded-xl text-zinc-400 transition-all group/nav-item hover:text-black dark:hover:text-white py-2 px-3"
              >
                <span
                  class="inline-flex w-2 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover/nav-item:w-4 group-hover/nav-item:bg-black dark:group-hover/nav-item:bg-white"
                ></span>
                <span class="font-medium text-xs" x-text="child.title"></span>
              </a>
            </li>
          </template>
        </ul>
      </li>
      <li x-show="!loading && !error && !hasChildren(item)">
        <a
          :href="item.href"
          class="w-full flex items-center gap-x-2 bg-transparent rounded-xl text-zinc-400 transition-all group/nav-item hover:text-black dark:hover:text-white py-2 px-3"
        >
          <span
            class="inline-flex w-2 h-px bg-zinc-200 dark:bg-zinc-800 transition-all group-hover/nav-item:w-4 group-hover/nav-item:bg-black dark:group-hover/nav-item:bg-white"
          ></span>
          <span class="font-medium text-xs" x-text="item.title"></span>
        </a>
      </li>
    </template>
  </ul>
</li>
