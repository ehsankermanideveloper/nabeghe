<!-- categories (mobile offcanvas) — server-side rendered -->
<li x-data="{ open: false }" class="w-full">
  <button
    type="button"
    class="w-full flex items-center gap-x-2 relative transition-all hover:text-foreground py-2"
    x-bind:class="open ? 'text-foreground' : 'text-muted'"
    x-on:click="open = !open"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
      <path
        fill-rule="evenodd"
        d="M3 9a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75A.75.75 0 0 1 3 9Zm0 6.75a.75.75 0 0 1 .75-.75h16.5a.75.75 0 0 1 0 1.5H3.75a.75.75 0 0 1-.75-.75Z"
        clip-rule="evenodd"
      ></path>
    </svg>
    <span class="font-semibold text-xs"><%= t('nav_category') %></span>
    <span class="absolute <%= dir === 'ltr' ? 'right-3' : 'left-3' %> transition-transform" x-bind:class="open ? 'rotate-180' : ''">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
      </svg>
    </span>
  </button>

  <div class="flex flex-col" x-show="open" x-transition x-cloak style="display: none">

    <a
      href="<%= lp %>/courses"
      class="flex items-center gap-2 text-primary font-bold text-xs py-2 px-3 rounded-xl hover:bg-secondary transition-colors"
    >
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-primary shrink-0"></span>
      <%= t('nav_all_categories') %>
    </a>

    <% if (typeof menuCategories !== 'undefined') { %>
    <% menuCategories.forEach(function(item) { %>
    <div x-data="{ openChild: false }">
      <div class="flex items-center">
        <a
          href="<%= lp %><%= item.href %>"
          class="flex-1 flex items-center gap-2 text-foreground font-semibold text-xs py-2 px-3 rounded-xl hover:text-primary transition-colors"
        >
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-border shrink-0"></span>
          <%= loc(item.title) %>
        </a>
        <% if (item.children && item.children.length > 0) { %>
        <button
          type="button"
          class="p-2 text-muted hover:text-foreground transition-colors"
          x-on:click="openChild = !openChild"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"
            class="w-4 h-4 transition-transform" x-bind:class="openChild ? 'rotate-180' : ''">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
          </svg>
        </button>
        <% } %>
      </div>
      <% if (item.children && item.children.length > 0) { %>
      <ul class="flex flex-col <%= dir === 'ltr' ? 'pl-6 border-l ml-4' : 'pr-6 border-r mr-4' %> border-border" x-show="openChild" x-cloak x-transition>
        <% item.children.forEach(function(child) { %>
        <li>
          <a
            href="<%= lp %><%= child.href %>"
            class="flex items-center gap-2 text-muted text-xs font-medium py-1.5 px-3 rounded-xl hover:text-primary transition-colors"
          >
            <span class="inline-block w-1 h-1 rounded-full bg-border shrink-0"></span>
            <%= loc(child.title) %>
          </a>
        </li>
        <% }) %>
      </ul>
      <% } %>
    </div>
    <% }) %>
    <% } %>

  </div>
</li>
