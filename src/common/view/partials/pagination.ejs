<%
/**
 * Shared pagination partial
 * Required locals:
 *   pagination  — { page, totalPages, hasPreviousPage, hasNextPage }
 *   baseUrl     — e.g. '/blog' or '/courses'
 *   query       — raw query object; undefined/null/empty values are stripped automatically
 */
function buildHref(targetPage) {
  const clean = {};
  if (query) {
    for (const k in query) {
      const v = query[k];
      if (k === 'page' || k === 'limit') continue;
      if (v !== undefined && v !== null && v !== '' && v !== 'undefined') {
        clean[k] = v;
      }
    }
  }
  clean.page = targetPage;
  return baseUrl + '?' + new URLSearchParams(clean).toString();
}

const startPage = Math.max(1, pagination.page - 2);
const endPage   = Math.min(pagination.totalPages, pagination.page + 2);
%>
<% if (pagination && pagination.totalPages > 1) { %>
<div class="flex items-center justify-center gap-2 mt-8">

  <% if (pagination.hasPreviousPage) { %>
  <a href="<%= buildHref(pagination.page - 1) %>"
     class="h-11 w-11 inline-flex items-center justify-center bg-secondary rounded-2xl text-muted hover:text-primary transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
      <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
    </svg>
  </a>
  <% } %>

  <% if (startPage > 1) { %>
  <a href="<%= buildHref(1) %>"
     class="h-11 w-11 inline-flex items-center justify-center rounded-2xl font-semibold text-sm bg-secondary text-foreground hover:text-primary transition-colors">1</a>
  <% if (startPage > 2) { %>
  <span class="h-11 w-11 inline-flex items-center justify-center text-muted text-sm">…</span>
  <% } %>
  <% } %>

  <% for (let p = startPage; p <= endPage; p++) { %>
  <a href="<%= buildHref(p) %>"
     class="h-11 w-11 inline-flex items-center justify-center rounded-2xl font-semibold text-sm transition-colors <%= p === pagination.page ? 'bg-primary text-primary-foreground' : 'bg-secondary text-foreground hover:text-primary' %>">
    <%= p %>
  </a>
  <% } %>

  <% if (endPage < pagination.totalPages) { %>
  <% if (endPage < pagination.totalPages - 1) { %>
  <span class="h-11 w-11 inline-flex items-center justify-center text-muted text-sm">…</span>
  <% } %>
  <a href="<%= buildHref(pagination.totalPages) %>"
     class="h-11 w-11 inline-flex items-center justify-center rounded-2xl font-semibold text-sm bg-secondary text-foreground hover:text-primary transition-colors"><%= pagination.totalPages %></a>
  <% } %>

  <% if (pagination.hasNextPage) { %>
  <a href="<%= buildHref(pagination.page + 1) %>"
     class="h-11 w-11 inline-flex items-center justify-center bg-secondary rounded-2xl text-muted hover:text-primary transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
      <path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
    </svg>
  </a>
  <% } %>

</div>
<% } %>
