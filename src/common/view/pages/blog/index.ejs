<main class="flex-auto py-5">
  <div class="max-w-7xl space-y-8 px-4 mx-auto">

    <!-- section:title -->
    <div class="flex items-center gap-5 bg-gradient-to-l from-secondary to-background rounded-2xl p-5">
      <span class="flex items-center justify-center w-12 h-12 bg-primary text-primary-foreground rounded-full">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
          <path d="M10.75 16.82A7.462 7.462 0 0 1 15 15.5c.71 0 1.396.098 2.046.282A.75.75 0 0 0 18 15.06v-11a.75.75 0 0 0-.546-.721A9.006 9.006 0 0 0 15 3a8.963 8.963 0 0 0-4.25 1.065V16.82ZM9.25 4.065A8.963 8.963 0 0 0 5 3c-.85 0-1.673.118-2.454.339A.75.75 0 0 0 2 4.06v11a.75.75 0 0 0 .954.721A7.506 7.506 0 0 1 5 15.5c1.579 0 3.042.487 4.25 1.32V4.065Z" />
        </svg>
      </span>
      <div class="flex flex-col space-y-2">
        <% if (currentCategory) { %>
        <span class="font-black xs:text-2xl text-lg text-primary"><%= currentCategory.title %></span>
        <span class="font-semibold text-xs text-muted"><a href="/blog" class="hover:underline">مقالات</a> › <%= currentCategory.title %></span>
        <% } else { %>
        <span class="font-black xs:text-2xl text-lg text-primary">مقالات آموزشی</span>
        <span class="font-semibold text-xs text-muted">بخوان، یاد بگیر، پیشرفت کن</span>
        <% } %>
      </div>
    </div>
    <!-- end section:title -->

    <div class="grid md:grid-cols-12 grid-cols-1 items-start gap-5">

      <!-- sidebar -->
      <div class="md:block hidden lg:col-span-3 md:col-span-4 md:sticky md:top-24">
        <form method="GET" action="/blog" id="filterForm">
          <% if (query && query.category) { %>
          <input type="hidden" name="category" value="<%= query.category %>" />
          <% } %>
          <div class="w-full flex flex-col space-y-3 mb-3">
            <span class="font-bold text-sm text-foreground">جستجو مقاله</span>
            <div class="flex items-center relative">
              <input type="text" name="q" value="<%= query && query.q ? query.q : '' %>"
                class="w-full !ring-0 !ring-offset-0 h-10 bg-secondary border-0 rounded-xl text-sm text-foreground pr-4 pl-10"
                placeholder="عنوان مقاله...">
              <button type="submit" class="absolute left-3 text-muted hover:text-primary transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                  <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd" />
                </svg>
              </button>
            </div>
          </div>

          <!-- categories accordion -->
          <% if (categories && categories.length) { %>
          <div class="flex flex-col divide-y divide-border" x-data="{ open: true }">
            <div class="w-full space-y-2 py-3">
              <button type="button"
                class="w-full h-11 flex items-center justify-between gap-x-2 relative bg-secondary rounded-2xl transition hover:text-primary px-3"
                x-bind:class="open ? 'text-primary' : 'text-foreground'"
                x-on:click="open = !open">
                <span class="font-bold text-sm">دسته‌بندی</span>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                  class="w-5 h-5 transition-transform" x-bind:class="open ? 'rotate-180' : ''">
                  <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                </svg>
              </button>
              <div x-show="open" x-transition class="flex flex-wrap gap-2 px-1">
                <a href="/blog<%= query && query.q ? '?q=' + encodeURIComponent(query.q) : '' %>"
                  class="inline-flex items-center h-8 rounded-full text-xs font-semibold px-3 transition-colors <%= !currentCategory ? 'bg-primary text-primary-foreground' : 'bg-secondary text-muted hover:text-primary' %>">
                  همه
                </a>
                <% categories.forEach(function(cat) { %>
                <a href="/blog?category=<%= cat.slug %><%= query && query.q ? '&q=' + encodeURIComponent(query.q) : '' %>"
                  class="inline-flex items-center h-8 rounded-full text-xs font-semibold px-3 transition-colors <%= currentCategory && currentCategory.slug === cat.slug ? 'bg-primary text-primary-foreground' : 'bg-secondary text-muted hover:text-primary' %>">
                  <%= cat.title %>
                </a>
                <% }); %>
              </div>
            </div>
          </div>
          <% } %>
        </form>
      </div>
      <!-- end sidebar -->

      <!-- articles grid -->
      <div class="lg:col-span-9 md:col-span-8 col-span-1">

        <!-- mobile search -->
        <form method="GET" action="/blog" class="md:hidden mb-5">
          <% if (query && query.category) { %>
          <input type="hidden" name="category" value="<%= query.category %>" />
          <% } %>
          <div class="flex items-center relative">
            <input type="text" name="q" value="<%= query && query.q ? query.q : '' %>"
              class="w-full !ring-0 !ring-offset-0 h-10 bg-secondary border-0 rounded-xl text-sm text-foreground pr-4 pl-10"
              placeholder="جستجوی مقاله...">
            <button type="submit" class="absolute left-3 text-muted">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd" />
              </svg>
            </button>
          </div>
        </form>

        <% if (articles && articles.length > 0) { %>
        <div class="grid sm:grid-cols-2 xl:grid-cols-3 grid-cols-1 gap-5">
          <% articles.forEach(function(article) { %>
          <!-- article:card -->
          <div class="flex flex-col bg-background border border-border rounded-2xl overflow-hidden transition-shadow hover:shadow-lg hover:shadow-black/5">
            <a href="/blog/<%= article.slug %>" class="block relative aspect-video bg-secondary overflow-hidden">
              <% if (article.thumbnail) { %>
              <img src="<%= article.thumbnail %>" class="w-full h-full object-cover transition-transform hover:scale-105" alt="<%= article.title %>" />
              <% } else { %>
              <div class="w-full h-full flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-12 h-12 text-muted/30">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.75 16.82A7.462 7.462 0 0 1 15 15.5c.71 0 1.396.098 2.046.282A.75.75 0 0 0 18 15.06v-11a.75.75 0 0 0-.546-.721A9.006 9.006 0 0 0 15 3a8.963 8.963 0 0 0-4.25 1.065V16.82ZM9.25 4.065A8.963 8.963 0 0 0 5 3c-.85 0-1.673.118-2.454.339A.75.75 0 0 0 2 4.06v11a.75.75 0 0 0 .954.721A7.506 7.506 0 0 1 5 15.5c1.579 0 3.042.487 4.25 1.32V4.065Z" />
                </svg>
              </div>
              <% } %>
              <% if (article.category) { %>
              <span class="absolute top-3 right-3 inline-flex items-center bg-primary/90 rounded-full font-semibold text-xs text-primary-foreground py-1 px-3">
                <%= article.category.title %>
              </span>
              <% } %>
            </a>
            <div class="flex flex-col flex-1 p-4 space-y-3">
              <h2 class="font-bold text-sm">
                <a href="/blog/<%= article.slug %>" class="line-clamp-2 text-foreground transition-colors hover:text-primary">
                  <%= article.title %>
                </a>
              </h2>
              <% if (article.shortDescription) { %>
              <p class="text-xs text-muted line-clamp-2 flex-1"><%= article.shortDescription %></p>
              <% } %>
              <div class="flex items-center justify-between gap-3 pt-2 border-t border-border">
                <div class="flex items-center gap-2 min-w-0">
                  <div class="flex-shrink-0 w-7 h-7 rounded-full bg-secondary border border-border flex items-center justify-center overflow-hidden">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-muted">
                      <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM3.751 20.105a8.25 8.25 0 0 1 16.498 0 .75.75 0 0 1-.437.695A18.683 18.683 0 0 1 12 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 0 1-.437-.695Z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <span class="line-clamp-1 font-semibold text-xs text-muted">
                    <%= article.author ? (article.author.displayName || 'نویسنده') : 'نویسنده' %>
                  </span>
                </div>
                <div class="flex items-center gap-3 flex-shrink-0 text-muted">
                  <% if (article.readTime > 0) { %>
                  <div class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                    <span class="font-semibold text-xs"><%= article.readTime %> دقیقه</span>
                  </div>
                  <% } %>
                  <div class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                    <span class="font-semibold text-xs"><%= article.viewCount %></span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- end article:card -->
          <% }); %>
        </div>

        <!-- pagination -->
        <% if (pagination && pagination.totalPages > 1) { %>
        <div class="flex items-center justify-center gap-2 mt-8">
          <% if (pagination.hasPreviousPage) { %>
          <a href="/blog?<%= new URLSearchParams({ ...query, page: pagination.page - 1 }).toString() %>"
            class="h-10 w-10 inline-flex items-center justify-center bg-secondary rounded-full text-muted hover:text-primary transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
              <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
          </a>
          <% } %>
          <% for (var p = Math.max(1, pagination.page - 2); p <= Math.min(pagination.totalPages, pagination.page + 2); p++) { %>
          <a href="/blog?<%= new URLSearchParams({ ...query, page: p }).toString() %>"
            class="h-10 w-10 inline-flex items-center justify-center rounded-full font-semibold text-sm transition-colors <%= p === pagination.page ? 'bg-primary text-primary-foreground' : 'bg-secondary text-muted hover:text-primary' %>">
            <%= p %>
          </a>
          <% } %>
          <% if (pagination.hasNextPage) { %>
          <a href="/blog?<%= new URLSearchParams({ ...query, page: pagination.page + 1 }).toString() %>"
            class="h-10 w-10 inline-flex items-center justify-center bg-secondary rounded-full text-muted hover:text-primary transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
              <path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
            </svg>
          </a>
          <% } %>
        </div>
        <% } %>

        <% } else { %>
        <div class="flex flex-col items-center justify-center py-20 space-y-4 text-center">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-16 h-16 text-muted/30">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.75 16.82A7.462 7.462 0 0 1 15 15.5c.71 0 1.396.098 2.046.282A.75.75 0 0 0 18 15.06v-11a.75.75 0 0 0-.546-.721A9.006 9.006 0 0 0 15 3a8.963 8.963 0 0 0-4.25 1.065V16.82ZM9.25 4.065A8.963 8.963 0 0 0 5 3c-.85 0-1.673.118-2.454.339A.75.75 0 0 0 2 4.06v11a.75.75 0 0 0 .954.721A7.506 7.506 0 0 1 5 15.5c1.579 0 3.042.487 4.25 1.32V4.065Z" />
          </svg>
          <p class="font-semibold text-muted">مقاله‌ای یافت نشد</p>
          <% if (query && (query.q || query.category)) { %>
          <a href="/blog" class="inline-flex items-center gap-1 text-primary font-semibold text-sm hover:underline">
            نمایش همه مقالات
          </a>
          <% } %>
        </div>
        <% } %>
      </div>
      <!-- end articles grid -->

    </div>
  </div>
</main>
