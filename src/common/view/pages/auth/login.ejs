<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'fa' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'rtl' %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg" />
    <link rel="stylesheet" href="/assets/css/fonts.css" />
    <link rel="stylesheet" href="/assets/css/app.css" />
    <title><%= t('auth_login_title') %> — <%= t('site_name_short') %></title>
    <script>(function(){if(localStorage.getItem('darkMode')!=='false')document.documentElement.classList.add('dark');}());</script>
  </head>
  <body>
    <div class="min-h-screen flex items-center justify-center bg-background p-5">
      <div class="w-full max-w-sm space-y-5">
        <% if (showDevHint) { %>
          <div
            class="rounded-xl border border-primary/30 bg-primary/5 px-4 py-3 text-center text-xs text-muted"
          >
            <%= t('auth_dev_mode') %>
            <strong dir="ltr" class="text-foreground">252525</strong>
            <%= t('auth_dev_no_sms') %>
          </div>
        <% } %>
        <% if (error) { %>
          <div
            class="rounded-xl border border-error/40 bg-error/10 px-4 py-3 text-center text-sm text-error"
          >
            <%= error %>
          </div>
        <% } %>
        <div class="bg-gradient-to-b from-secondary to-background rounded-3xl space-y-5 px-5 pb-5">
          <div class="bg-background rounded-b-3xl space-y-2 p-5">
            <a href="<%= lp %>/" class="inline-flex items-center gap-2 text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                <path
                  d="M12 .75a8.25 8.25 0 0 0-4.135 15.39c.686.398 1.115 1.008 1.134 1.623a.75.75 0 0 0 .577.706c.352.083.71.148 1.074.195.323.041.6-.218.6-.544v-4.661a6.714 6.714 0 0 1-.937-.171.75.75 0 1 1 .374-1.453 5.261 5.261 0 0 0 2.626 0 .75.75 0 1 1 .374 1.452 6.712 6.712 0 0 1-.937.172v4.66c0 .327.277.586.6.545.364-.047.722-.112 1.074-.195a.75.75 0 0 0 .577-.706c.02-.615.448-1.225 1.134-1.623A8.25 8.25 0 0 0 12 .75Z"
                />
              </svg>
              <span class="flex flex-col items-start">
                <span class="font-semibold text-sm text-muted"><%= t('footer_academy') %></span>
                <span class="font-black text-xl"><%= t('site_name_short') %></span>
              </span>
            </a>
          </div>
          <form action="<%= lp %>/auth/login?returnTo=<%= encodeURIComponent(returnTo) %>" method="post" class="space-y-3">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="flex items-center gap-3">
              <div class="flex items-center gap-1">
                <div class="w-1 h-1 bg-foreground rounded-full"></div>
                <div class="w-2 h-2 bg-foreground rounded-full"></div>
              </div>
              <div class="font-black text-foreground"><%= t('auth_login_title') %></div>
            </div>
            <div class="text-sm text-muted space-y-3">
              <p><%= t('auth_login_greeting') %></p>
              <p><%= t('auth_login_hint') %></p>
            </div>
            <div class="flex items-center relative">
              <input
                type="text"
                name="identifier"
                dir="ltr"
                required
                autocomplete="username"
                placeholder="<%= t('auth_login_placeholder') %>"
                class="form-input w-full h-11 !ring-0 !ring-offset-0 bg-secondary border-border focus:border-border rounded-xl text-sm text-foreground placeholder:text-right px-5"
              />
            </div>
            <button
              type="submit"
              class="flex items-center justify-center gap-1 w-full h-10 bg-primary rounded-full text-primary-foreground transition-all hover:opacity-80 px-4"
            >
              <span class="font-semibold text-sm"><%= t('btn_go') %></span>
            </button>
          </form>

          <div id="__or_divider"<% if (!(typeof googleEnabled !== 'undefined' && googleEnabled)) { %> style="display:none"<% } %> class="flex items-center gap-3 px-1">
            <span class="flex-1 h-px bg-border"></span>
            <span class="text-xs text-muted"><%= t('auth_or') %></span>
            <span class="flex-1 h-px bg-border"></span>
          </div>

          <div class="flex gap-3">
            <% if (typeof googleEnabled !== 'undefined' && googleEnabled) { %>
            <a
              href="<%= lp %>/auth/google?returnTo=<%= encodeURIComponent(returnTo) %>"
              class="flex flex-1 items-center justify-center gap-2 h-11 bg-background border border-border rounded-full text-foreground transition-all hover:bg-secondary px-3"
              title="<%= t('auth_google_btn') %>"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" class="w-5 h-5 shrink-0">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                <path fill="none" d="M0 0h48v48H0z"/>
              </svg>
              <span class="font-semibold text-sm"><%= t('auth_google_btn') %></span>
            </a>
            <% } %>

            <button id="__pk_btn" type="button" style="display:none"
              class="flex flex-1 items-center justify-center gap-2 h-11 bg-background border border-border rounded-full text-foreground transition-all hover:bg-secondary px-3 disabled:opacity-50 disabled:cursor-not-allowed"
              title="<%= t('auth_passkey_btn') %>"
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 shrink-0">
                <path fill-rule="evenodd" d="M12 1.5a5.25 5.25 0 0 0-5.25 5.25v3a3 3 0 0 0-3 3v6.75a3 3 0 0 0 3 3h10.5a3 3 0 0 0 3-3v-6.75a3 3 0 0 0-3-3v-3c0-2.9-2.35-5.25-5.25-5.25Zm3.75 8.25v-3a3.75 3.75 0 1 0-7.5 0v3h7.5Z" clip-rule="evenodd" />
              </svg>
              <span class="font-semibold text-sm"><%= t('auth_passkey_btn') %></span>
            </button>
          </div>

          <div id="__pk_err" style="display:none" class="rounded-xl border border-error/40 bg-error/10 px-4 py-3 text-center text-sm text-error"></div>

        </div>
      </div>
    </div>
    <script src="/assets/js/dependencies/alpinejs.min.js" defer></script>
    <script src="/assets/js/app.js" defer></script>
    <script>
    (function(){
      if (!window.PublicKeyCredential) return;
      function b64uToBuf(s){var b=atob(s.replace(/-/g,'+').replace(/_/g,'/'));var u=new Uint8Array(b.length);for(var i=0;i<b.length;i++)u[i]=b.charCodeAt(i);return u.buffer;}
      function bufToB64u(b){var u=new Uint8Array(b),s='';for(var i=0;i<u.byteLength;i++)s+=String.fromCharCode(u[i]);return btoa(s).replace(/\+/g,'-').replace(/\//g,'_').replace(/=+$/,'');}
      var btn=document.getElementById('__pk_btn');
      btn.style.display='';
      var orDiv=document.getElementById('__or_divider');
      if(orDiv)orDiv.style.display='';
      var errEl=document.getElementById('__pk_err');
      var lp='<%= lp %>';
      var returnTo='<%= encodeURIComponent(returnTo) %>';
      function showErr(msg){errEl.textContent=msg;errEl.style.display='';}
      btn.addEventListener('click',function(){
        errEl.style.display='none';
        btn.disabled=true;
        fetch(lp+'/auth/passkey/authenticate/options',{method:'POST',headers:{'Accept':'application/json'}})
          .then(function(r){if(!r.ok)throw new Error();return r.json();})
          .then(function(opts){
            opts.challenge=b64uToBuf(opts.challenge);
            if(opts.allowCredentials)opts.allowCredentials=opts.allowCredentials.map(function(c){return Object.assign({},c,{id:b64uToBuf(c.id)});});
            return navigator.credentials.get({publicKey:opts});
          })
          .then(function(cred){
            var payload={id:cred.id,rawId:bufToB64u(cred.rawId),type:cred.type,response:{clientDataJSON:bufToB64u(cred.response.clientDataJSON),authenticatorData:bufToB64u(cred.response.authenticatorData),signature:bufToB64u(cred.response.signature),userHandle:cred.response.userHandle?bufToB64u(cred.response.userHandle):null}};
            return fetch(lp+'/auth/passkey/authenticate/verify?returnTo='+returnTo,{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({response:payload})});
          })
          .then(function(r){return r.json().then(function(d){if(!r.ok||!d.ok)throw new Error(d.message||'');return d;});})
          .then(function(d){window.location.href=d.redirectTo||'/';})
          .catch(function(e){if(e&&e.name==='NotAllowedError')return;showErr(e&&e.message?e.message:'<%= t("msg_error_server") %>');btn.disabled=false;});
      });
    })();
    </script>
  </body>
</html>
