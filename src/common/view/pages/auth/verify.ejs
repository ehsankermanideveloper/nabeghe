<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'fa' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'rtl' %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg" />
    <link rel="stylesheet" href="/assets/css/fonts.css" />
    <link rel="stylesheet" href="/assets/css/app.css" />
    <title><%= t('auth_verify_title') %> — <%= t('site_name_short') %></title>
    <script>(function(){if(localStorage.getItem('darkMode')!=='false')document.documentElement.classList.add('dark');}());</script>
  </head>
  <body>
    <div class="min-h-screen flex items-center justify-center bg-background p-5">
      <div class="w-full max-w-sm space-y-5">
        <% if (showDevHint) { %>
          <div
            class="rounded-xl border border-primary/30 bg-primary/5 px-4 py-3 text-center text-xs text-muted"
          >
            <%= t('auth_otp_label') %>
            <strong dir="ltr" class="text-foreground">252525</strong>
          </div>
        <% } %>
        <% if (error) { %>
          <div
            class="rounded-xl border border-error/40 bg-error/10 px-4 py-3 text-center text-sm text-error"
          >
            <%= error %>
          </div>
        <% } %>
        <div class="bg-gradient-to-b from-secondary to-background rounded-3xl space-y-5 px-5 pb-5">
          <div class="bg-background rounded-b-3xl space-y-2 p-5">
            <a href="<%= lp %>/" class="inline-flex items-center gap-2 text-primary">
              <span class="font-black text-xl"><%= t('site_name_short') %></span>
            </a>
          </div>
          <form
            action="<%= lp %>/auth/verify?returnTo=<%= encodeURIComponent(returnTo) %>"
            method="post"
            class="space-y-3"
          >
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <div class="font-black text-foreground"><%= t('auth_verify_title') %></div>
            <p class="text-sm text-muted">
              <% if (pendingKind === 'email') { %>
                <%= t('auth_verify_code_email') %> <span dir="ltr"><%= masked %></span> <%= t('auth_verify_sim') %>
              <% } else { %>
                <%= t('auth_verify_code_phone') %> <span dir="ltr"><%= masked %></span> <%= t('auth_verify_sim') %>
              <% } %>
            </p>
            <input
              type="text"
              name="code"
              inputmode="numeric"
              dir="ltr"
              required
              pattern="[0-9]+"
              maxlength="6"
              autocomplete="one-time-code"
              placeholder="252525"
              class="form-input w-full h-11 bg-secondary border-border rounded-xl text-lg tracking-widest text-center text-foreground px-5"
            />
            <button
              type="submit"
              class="flex items-center justify-center w-full h-10 bg-primary rounded-full text-primary-foreground font-semibold text-sm hover:opacity-80"
            >
              <%= t('auth_verify_btn') %>
            </button>
          </form>
          <a href="<%= lp %>/auth/login" class="block text-center text-sm text-primary hover:underline"
            ><%= t('auth_verify_change') %></a
          >
        </div>
      </div>
    </div>
    <script src="/assets/js/dependencies/alpinejs.min.js" defer></script>
    <script src="/assets/js/app.js" defer></script>

  </body>
</html>
