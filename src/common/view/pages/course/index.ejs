<main class="flex-auto py-5">
  <div class="max-w-7xl space-y-8 px-4 mx-auto">
    <% const _bc = currentCategory
      ? [{ name: t('nav_home'), url: lp + '/' }, { name: t('nav_courses'), url: lp + '/courses' }, { name: loc(currentCategory.title), url: null }]
      : [{ name: t('nav_home'), url: lp + '/' }, { name: t('nav_courses'), url: null }];
    %>
    <%- include('../../partials/_breadcrumb', { breadcrumbs: _bc }) %>

    <!-- section:title -->
    <div class="flex items-center gap-5 bg-gradient-to-l from-secondary to-background rounded-2xl p-5">
      <span class="flex items-center justify-center w-12 h-12 bg-primary text-primary-foreground rounded-full">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <path fill-rule="evenodd" d="M3 6a3 3 0 0 1 3-3h2.25a3 3 0 0 1 3 3v2.25a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6Zm9.75 0a3 3 0 0 1 3-3H18a3 3 0 0 1 3 3v2.25a3 3 0 0 1-3 3h-2.25a3 3 0 0 1-3-3V6ZM3 15.75a3 3 0 0 1 3-3h2.25a3 3 0 0 1 3 3V18a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3v-2.25Zm9.75 0a3 3 0 0 1 3-3H18a3 3 0 0 1 3 3V18a3 3 0 0 1-3 3h-2.25a3 3 0 0 1-3-3v-2.25Z" clip-rule="evenodd" />
        </svg>
      </span>
      <div class="flex flex-col space-y-2">
        <% if (currentCategory) { %>
        <h1 class="font-black xs:text-2xl text-lg text-primary"><%= loc(currentCategory.title) %></h1>
        <p class="font-semibold text-xs text-muted"><a href="<%= lp %>/courses" class="hover:underline"><%= t('course_list_title') %></a> › <%= loc(currentCategory.title) %></p>
        <% } else { %>
        <h1 class="font-black xs:text-2xl text-lg text-primary"><%= t('course_list_title') %></h1>
        <p class="font-semibold text-xs text-muted"><%= t('course_list_subtitle') %></p>
        <% } %>
      </div>
    </div>
    <!-- end section:title -->

    <div class="grid md:grid-cols-12 grid-cols-1 items-start gap-5">

      <!-- sidebar -->
      <div class="md:block hidden lg:col-span-3 md:col-span-4 md:sticky md:top-24">
        <form method="GET" action="<%= lp %>/courses" id="filterForm">
          <% if (query && query.category) { %>
          <input type="hidden" name="category" value="<%= query.category %>" />
          <% } %>
          <div class="w-full flex flex-col space-y-3 mb-3">
            <span class="font-bold text-sm text-foreground"><%= t('course_search') %></span>
            <div class="flex items-center relative">
              <input type="text" name="q" value="<%= query && query.q ? query.q : '' %>"
                class="w-full !ring-0 !ring-offset-0 h-10 bg-secondary border-0 rounded-xl text-sm text-foreground search-pad"
                placeholder="<%= t('course_search_placeholder') %>">
              <span class="absolute search-icon-wrap text-muted">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                  <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd" />
                </svg>
              </span>
            </div>
          </div>

          <!-- accordion: course type -->
          <div class="flex flex-col divide-y divide-border" x-data="{ open: true }">
            <div class="w-full space-y-2 py-3">
              <button type="button"
                class="w-full h-11 flex items-center justify-between gap-x-2 relative bg-secondary rounded-2xl transition hover:text-primary px-3"
                x-bind:class="open ? 'text-primary' : 'text-foreground'"
                x-on:click="open = !open">
                <span class="flex items-center gap-x-2">
                  <span class="flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
                    </svg>
                  </span>
                  <span class="font-semibold text-sm text-right"><%= t('label_course_type') %></span>
                </span>
                <span x-bind:class="open ? 'rotate-180' : ''">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                  </svg>
                </span>
              </button>

              <div class="bg-secondary rounded-2xl relative p-3" x-show="open">
                <div class="space-y-2">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="sort" value="" class="!ring-0 !ring-offset-0 bg-border border-0"
                      <%= (!query || !query.sort || (query.sort !== 'free' && query.sort !== 'paid')) ? 'checked' : '' %>
                      onchange="document.getElementById('filterForm').submit()" />
                    <span class="text-sm text-muted"><%= t('label_all') %></span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="sort" value="free" class="!ring-0 !ring-offset-0 bg-border border-0"
                      <%= query && query.sort === 'free' ? 'checked' : '' %>
                      onchange="document.getElementById('filterForm').submit()" />
                    <span class="text-sm text-muted"><%= t('label_free') %></span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="sort" value="paid" class="!ring-0 !ring-offset-0 bg-border border-0"
                      <%= query && query.sort === 'paid' ? 'checked' : '' %>
                      onchange="document.getElementById('filterForm').submit()" />
                    <span class="text-sm text-muted"><%= t('label_paid') %></span>
                  </label>
                </div>
              </div>
            </div>

            <!-- level filter -->
            <div class="w-full space-y-2 py-3" x-data="{ open: true }">
              <button type="button"
                class="w-full h-11 flex items-center justify-between gap-x-2 relative bg-secondary rounded-2xl transition hover:text-primary px-3"
                x-bind:class="open ? 'text-primary' : 'text-foreground'"
                x-on:click="open = !open">
                <span class="flex items-center gap-x-2">
                  <span class="flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
                    </svg>
                  </span>
                  <span class="font-semibold text-sm text-right"><%= t('label_level') %></span>
                </span>
                <span x-bind:class="open ? 'rotate-180' : ''">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                  </svg>
                </span>
              </button>
              <div class="bg-secondary rounded-2xl relative p-3" x-show="open">
                <div class="space-y-2">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="level" value="" class="!ring-0 !ring-offset-0 bg-border border-0"
                      <%= !query || !query.level ? 'checked' : '' %>
                      onchange="document.getElementById('filterForm').submit()" />
                    <span class="text-sm text-muted"><%= t('label_all_levels') %></span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="level" value="beginner" class="!ring-0 !ring-offset-0 bg-border border-0"
                      <%= query && query.level === 'beginner' ? 'checked' : '' %>
                      onchange="document.getElementById('filterForm').submit()" />
                    <span class="text-sm text-muted"><%= t('label_beginner') %></span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="level" value="intermediate" class="!ring-0 !ring-offset-0 bg-border border-0"
                      <%= query && query.level === 'intermediate' ? 'checked' : '' %>
                      onchange="document.getElementById('filterForm').submit()" />
                    <span class="text-sm text-muted"><%= t('label_intermediate') %></span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="level" value="advanced" class="!ring-0 !ring-offset-0 bg-border border-0"
                      <%= query && query.level === 'advanced' ? 'checked' : '' %>
                      onchange="document.getElementById('filterForm').submit()" />
                    <span class="text-sm text-muted"><%= t('label_advanced') %></span>
                  </label>
                </div>
              </div>
            </div>

            <!-- category filter -->
            <% if (categories && categories.length > 0) { %>
            <div class="w-full space-y-2 py-3" x-data="{ open: true }">
              <button type="button"
                class="w-full h-11 flex items-center justify-between gap-x-2 relative bg-secondary rounded-2xl transition hover:text-primary px-3"
                x-bind:class="open ? 'text-primary' : 'text-foreground'"
                x-on:click="open = !open">
                <span class="flex items-center gap-x-2">
                  <span class="flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
                    </svg>
                  </span>
                  <span class="font-semibold text-sm text-right"><%= t('label_category') %></span>
                </span>
                <span x-bind:class="open ? 'rotate-180' : ''">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                  </svg>
                </span>
              </button>
              <div class="bg-secondary rounded-2xl relative p-3" x-show="open">
                <%- include('view/pages/course/_category-list') %>
              </div>
            </div>
            <% } %>
          </div>
        </form>
      </div>
      <!-- end sidebar -->

      <!-- main content -->
      <div class="lg:col-span-9 md:col-span-8">

        <!-- sort & filter(offcanvas) -->
        <div class="flex items-center gap-3 mb-5" x-data="{ offcanvasOpen: false }">

          <!-- sort dropdown -->
          <div x-data="{ open: false, selected: '<%= query && query.sort === 'popular' ? t('course_sort_popular') : query && query.sort === 'price_asc' ? t('course_sort_price_asc') : query && query.sort === 'price_desc' ? t('course_sort_price_desc') : query && query.sort === 'free' ? t('course_sort_free') : query && query.sort === 'paid' ? t('label_paid') : t('course_sort_newest') %>' }">
            <div class="flex items-center gap-3">
              <label class="sm:flex hidden items-center gap-1 font-semibold text-xs text-muted">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                  <path d="M10 3.75a2 2 0 1 0-4 0 2 2 0 0 0 4 0ZM17.25 4.5a.75.75 0 0 0 0-1.5h-5.5a.75.75 0 0 0 0 1.5h5.5ZM5 3.75a.75.75 0 0 1-.75.75h-1.5a.75.75 0 0 1 0-1.5h1.5a.75.75 0 0 1 .75.75ZM4.25 17a.75.75 0 0 0 0-1.5h-1.5a.75.75 0 0 0 0 1.5h1.5ZM17.25 17a.75.75 0 0 0 0-1.5h-5.5a.75.75 0 0 0 0 1.5h5.5ZM9 10a.75.75 0 0 1-.75.75h-5.5a.75.75 0 0 1 0-1.5h5.5A.75.75 0 0 1 9 10ZM17.25 10.75a.75.75 0 0 0 0-1.5h-1.5a.75.75 0 0 0 0 1.5h1.5ZM14 10a2 2 0 1 0-4 0 2 2 0 0 0 4 0ZM10 16.25a2 2 0 1 0-4 0 2 2 0 0 0 4 0Z" />
                </svg>
                <%= t('label_sort') %>
              </label>

              <div class="w-52 relative">
                <button x-on:click="open = !open"
                  class="flex items-center w-full h-11 relative bg-secondary rounded-2xl font-semibold text-xs text-foreground px-4">
                  <span class="line-clamp-1" x-text="selected"></span>
                  <span class="absolute <%= dir === 'ltr' ? 'right-3' : 'left-3' %> pointer-events-none transition-transform" x-bind:class="open ? 'rotate-180' : ''">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                    </svg>
                  </span>
                </button>

                <div class="absolute w-full bg-background rounded-2xl shadow-lg overflow-hidden mt-2 z-30" x-show="open" x-cloak x-on:click.away="open = false">
                  <ul class="max-h-48 overflow-y-auto">
                    <li class="font-medium text-xs text-foreground cursor-pointer hover:bg-secondary px-4 py-3"
                      x-on:click="selected = '<%= t('course_sort_newest') %>'; open = false; window.location.href = '<%= lp %>/courses?sort=newest<%= query && query.q ? '&q=' + encodeURIComponent(query.q) : '' %><%= query && query.level ? '&level=' + query.level : '' %><%= query && query.category ? '&category=' + query.category : '' %>'"><%= t('course_sort_newest') %></li>
                    <li class="font-medium text-xs text-foreground cursor-pointer hover:bg-secondary px-4 py-3"
                      x-on:click="selected = '<%= t('course_sort_popular') %>'; open = false; window.location.href = '<%= lp %>/courses?sort=popular<%= query && query.q ? '&q=' + encodeURIComponent(query.q) : '' %><%= query && query.level ? '&level=' + query.level : '' %><%= query && query.category ? '&category=' + query.category : '' %>'"><%= t('course_sort_popular') %></li>
                    <li class="font-medium text-xs text-foreground cursor-pointer hover:bg-secondary px-4 py-3"
                      x-on:click="selected = '<%= t('course_sort_price_asc') %>'; open = false; window.location.href = '<%= lp %>/courses?sort=price_asc<%= query && query.q ? '&q=' + encodeURIComponent(query.q) : '' %><%= query && query.level ? '&level=' + query.level : '' %><%= query && query.category ? '&category=' + query.category : '' %>'"><%= t('course_sort_price_asc') %></li>
                    <li class="font-medium text-xs text-foreground cursor-pointer hover:bg-secondary px-4 py-3"
                      x-on:click="selected = '<%= t('course_sort_price_desc') %>'; open = false; window.location.href = '<%= lp %>/courses?sort=price_desc<%= query && query.q ? '&q=' + encodeURIComponent(query.q) : '' %><%= query && query.level ? '&level=' + query.level : '' %><%= query && query.category ? '&category=' + query.category : '' %>'"><%= t('course_sort_price_desc') %></li>
                    <li class="font-medium text-xs text-foreground cursor-pointer hover:bg-secondary px-4 py-3"
                      x-on:click="selected = '<%= t('course_sort_free') %>'; open = false; window.location.href = '<%= lp %>/courses?sort=free<%= query && query.q ? '&q=' + encodeURIComponent(query.q) : '' %><%= query && query.level ? '&level=' + query.level : '' %><%= query && query.category ? '&category=' + query.category : '' %>'"><%= t('course_sort_free') %></li>
                  </ul>
                </div>
              </div>
            </div>
          </div>

          <!-- results count -->
          <% if (pagination) { %>
          <span class="text-xs text-muted mr-auto"><%= pagination.total %> <%= t('label_courses_count') %></span>
          <% } %>

          <!-- filter offcanvas button (mobile) -->
          <button type="button"
            class="md:hidden flex items-center gap-1 h-11 bg-secondary rounded-2xl text-foreground px-4"
            x-on:click="offcanvasOpen = true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z" />
            </svg>
            <span class="hidden sm:block font-semibold text-xs"><%= t('course_filter_title') %></span>
          </button>

          <!-- filter offcanvas -->
          <div x-cloak>
            <div class="fixed inset-y-0 xs:w-80 w-72 h-full bg-background overflow-y-auto transition-transform z-50 rtl:translate-x-full ltr:-translate-x-full <%= dir === 'ltr' ? 'left-0 rounded-r-2xl' : 'right-0 rounded-l-2xl' %>"
              x-bind:class="offcanvasOpen ? '!translate-x-0' : ''">
              <div class="flex items-center justify-between gap-x-4 sticky top-0 bg-background p-4 z-10">
                <div class="font-bold text-sm text-foreground"><%= t('course_filter_title') %></div>
                <button x-on:click="offcanvasOpen = false" class="text-foreground focus:outline-none hover:text-red-500">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
              <div class="p-4">
                <form method="GET" action="<%= lp %>/courses">
                  <!-- search -->
                  <div class="w-full flex flex-col space-y-3 mb-3">
                    <span class="font-bold text-sm text-foreground"><%= t('course_search') %></span>
                    <div class="flex items-center relative">
                      <input type="text" name="q" value="<%= query && query.q ? query.q : '' %>"
                        class="w-full !ring-0 !ring-offset-0 h-10 bg-secondary border-0 rounded-xl text-sm text-foreground search-pad"
                        placeholder="<%= t('course_search_placeholder') %>">
                      <span class="absolute search-icon-wrap text-muted">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                          <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd" />
                        </svg>
                      </span>
                    </div>
                  </div>

                  <div class="flex flex-col divide-y divide-border">

                    <!-- course type -->
                    <div class="w-full space-y-2 py-3" x-data="{ open: true }">
                      <button type="button"
                        class="w-full h-11 flex items-center justify-between gap-x-2 bg-secondary rounded-2xl px-3"
                        x-bind:class="open ? 'text-primary' : 'text-foreground'"
                        x-on:click="open = !open">
                        <span class="font-semibold text-sm"><%= t('label_course_type') %></span>
                        <span x-bind:class="open ? 'rotate-180' : ''">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                          </svg>
                        </span>
                      </button>
                      <div class="bg-secondary rounded-2xl p-3" x-show="open">
                        <div class="space-y-2">
                          <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="sort" value="" class="!ring-0 !ring-offset-0 bg-border border-0"
                              <%= (!query || !query.sort || (query.sort !== 'free' && query.sort !== 'paid')) ? 'checked' : '' %> />
                            <span class="text-sm text-muted"><%= t('label_all') %></span>
                          </label>
                          <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="sort" value="free" class="!ring-0 !ring-offset-0 bg-border border-0"
                              <%= query && query.sort === 'free' ? 'checked' : '' %> />
                            <span class="text-sm text-muted"><%= t('label_free') %></span>
                          </label>
                          <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="sort" value="paid" class="!ring-0 !ring-offset-0 bg-border border-0"
                              <%= query && query.sort === 'paid' ? 'checked' : '' %> />
                            <span class="text-sm text-muted"><%= t('label_paid') %></span>
                          </label>
                        </div>
                      </div>
                    </div>

                    <!-- level -->
                    <div class="w-full space-y-2 py-3" x-data="{ open: true }">
                      <button type="button"
                        class="w-full h-11 flex items-center justify-between gap-x-2 bg-secondary rounded-2xl px-3"
                        x-bind:class="open ? 'text-primary' : 'text-foreground'"
                        x-on:click="open = !open">
                        <span class="font-semibold text-sm"><%= t('label_level') %></span>
                        <span x-bind:class="open ? 'rotate-180' : ''">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                          </svg>
                        </span>
                      </button>
                      <div class="bg-secondary rounded-2xl p-3" x-show="open">
                        <div class="space-y-2">
                          <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="level" value="" class="!ring-0 !ring-offset-0 bg-border border-0" <%= !query || !query.level ? 'checked' : '' %> />
                            <span class="text-sm text-muted"><%= t('label_all_levels') %></span>
                          </label>
                          <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="level" value="beginner" class="!ring-0 !ring-offset-0 bg-border border-0" <%= query && query.level === 'beginner' ? 'checked' : '' %> />
                            <span class="text-sm text-muted"><%= t('label_beginner') %></span>
                          </label>
                          <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="level" value="intermediate" class="!ring-0 !ring-offset-0 bg-border border-0" <%= query && query.level === 'intermediate' ? 'checked' : '' %> />
                            <span class="text-sm text-muted"><%= t('label_intermediate') %></span>
                          </label>
                          <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="level" value="advanced" class="!ring-0 !ring-offset-0 bg-border border-0" <%= query && query.level === 'advanced' ? 'checked' : '' %> />
                            <span class="text-sm text-muted"><%= t('label_advanced') %></span>
                          </label>
                        </div>
                      </div>
                    </div>

                    <!-- categories -->
                    <% if (categories && categories.length > 0) { %>
                    <div class="w-full space-y-2 py-3" x-data="{ open: true }">
                      <button type="button"
                        class="w-full h-11 flex items-center justify-between gap-x-2 bg-secondary rounded-2xl px-3"
                        x-bind:class="open ? 'text-primary' : 'text-foreground'"
                        x-on:click="open = !open">
                        <span class="font-semibold text-sm"><%= t('label_category') %></span>
                        <span x-bind:class="open ? 'rotate-180' : ''">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                          </svg>
                        </span>
                      </button>
                      <div class="bg-secondary rounded-2xl p-3" x-show="open">
                        <%- include('view/pages/course/_category-list') %>
                      </div>
                    </div>
                    <% } %>

                  </div>
                  <button type="submit" class="w-full h-11 mt-4 bg-primary rounded-2xl text-primary-foreground font-semibold text-sm"><%= t('btn_filter') %></button>
                </form>
              </div>
            </div>
            <div class="fixed inset-0 bg-black/10 dark:bg-white/10 cursor-pointer transition-all duration-300 z-40"
              x-bind:class="offcanvasOpen ? 'opacity-100 visible' : 'opacity-0 invisible'"
              x-on:click="offcanvasOpen = false"></div>
          </div>
          <!-- end filter offcanvas -->
        </div>
        <!-- end sort & filter -->

        <!-- courses grid -->
        <% if (courses && courses.length > 0) { %>
        <div class="grid lg:grid-cols-3 sm:grid-cols-2 gap-x-5 gap-y-10">
          <% courses.forEach(function(course) { %>
          <%- include('../../partials/course-card', { course: course, isWishlisted: wishlistedIds && wishlistedIds.includes(course.id) }) %>
          <% }) %>
        </div>

        <!-- pagination -->
        <%- include('../../partials/pagination', { baseUrl: lp + '/courses', pagination, query }) %>

        <% } else { %>
        <!-- empty state -->
        <div class="flex flex-col items-center justify-center py-24 gap-4">
          <img src="/assets/images/theme/empty.svg" class="w-32 opacity-50" alt="" />
          <p class="text-muted font-semibold text-sm"><%= t('course_list_empty') %></p>
          <a href="<%= lp %>/courses" class="text-primary text-sm font-semibold hover:underline"><%= t('btn_view_all_courses') %></a>
        </div>
        <% } %>

      </div>
      <!-- end main content -->

    </div>
  </div>
</main>
