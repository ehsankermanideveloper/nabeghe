<%
  function buildCatParams(extra) {
    const p = [];
    if (extra && extra.category) p.push('category=' + extra.category);
    if (query && query.q) p.push('q=' + encodeURIComponent(query.q));
    if (query && query.sort) p.push('sort=' + query.sort);
    if (query && query.level) p.push('level=' + query.level);
    return p.length ? '?' + p.join('&') : '';
  }
  const _parentCats = categories.filter(function(c) { return !c.parentId; });
%>

<a href="/courses<%= buildCatParams(null) %>"
  class="flex items-center gap-2 px-3 py-2 rounded-xl font-semibold text-sm transition-colors mb-1 <%= !currentCategory ? 'text-primary bg-primary/10' : 'text-muted hover:text-foreground' %>">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 shrink-0">
    <path fill-rule="evenodd" d="M3 6a3 3 0 0 1 3-3h2.25a3 3 0 0 1 3 3v2.25a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3V6Zm9.75 0a3 3 0 0 1 3-3H18a3 3 0 0 1 3 3v2.25a3 3 0 0 1-3 3h-2.25a3 3 0 0 1-3-3V6ZM3 15.75a3 3 0 0 1 3-3h2.25a3 3 0 0 1 3 3V18a3 3 0 0 1-3 3H6a3 3 0 0 1-3-3v-2.25Zm9.75 0a3 3 0 0 1 3-3H18a3 3 0 0 1 3 3V18a3 3 0 0 1-3 3h-2.25a3 3 0 0 1-3-3v-2.25Z" clip-rule="evenodd" />
  </svg>
  همه دسته‌بندی‌ها
</a>

<% _parentCats.forEach(function(parent) { %>
<% const _children = categories.filter(function(c) { return c.parentId === parent.id; }); %>
<% if (_children.length > 0) { %>
<div class="mt-2">
  <div class="flex items-center gap-1.5 px-3 py-1 font-bold text-xs text-foreground">
    <span class="inline-block w-2 h-2 rounded-sm bg-primary/40 shrink-0"></span>
    <%= parent.title %>
  </div>
  <div class="mr-3 mt-0.5 border-r-2 border-border pr-2 space-y-0.5">
    <% _children.forEach(function(child) { %>
    <a href="/courses<%= buildCatParams({ category: child.slug }) %>"
      class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-xs font-medium transition-colors <%= currentCategory && currentCategory.id === child.id ? 'text-primary font-bold bg-primary/10' : 'text-muted hover:text-foreground' %>">
      <span class="inline-block w-1 h-1 rounded-full shrink-0 <%= currentCategory && currentCategory.id === child.id ? 'bg-primary' : 'bg-border' %>"></span>
      <%= child.title %>
    </a>
    <% }) %>
  </div>
</div>
<% } else { %>
<a href="/courses<%= buildCatParams({ category: parent.slug }) %>"
  class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm font-medium transition-colors mt-1 <%= currentCategory && currentCategory.id === parent.id ? 'text-primary font-bold bg-primary/10' : 'text-muted hover:text-foreground' %>">
  <span class="inline-block w-1.5 h-1.5 rounded-full shrink-0 <%= currentCategory && currentCategory.id === parent.id ? 'bg-primary' : 'bg-border' %>"></span>
  <%= parent.title %>
</a>
<% } %>
<% }) %>
