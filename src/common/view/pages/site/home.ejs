                                    class="w-5 h-5">
                                    <path fill-rule="evenodd"
                                        d="M9.664 1.319a.75.75 0 0 1 .672 0 41.059 41.059 0 0 1 8.198 5.424.75.75 0 0 1-.254 1.285 31.372 31.372 0 0 0-7.86 3.83.75.75 0 0 1-.84 0 31.508 31.508 0 0 0-2.08-1.287V9.394c0-.244.116-.463.302-.592a35.504 35.504 0 0 1 3.305-2.033.75.75 0 0 0-.714-1.319 37 37 0 0 0-3.446 2.12A2.216 2.216 0 0 0 6 9.393v.38a31.293 31.293 0 0 0-4.28-1.746.75.75 0 0 1-.254-1.285 41.059 41.059 0 0 1 8.198-5.424ZM6 11.459a29.848 29.848 0 0 0-2.455-1.158 41.029 41.029 0 0 0-.39 3.114.75.75 0 0 0 .419.74c.528.256 1.046.53 1.554.82-.21.324-.455.63-.739.914a.75.75 0 1 0 1.06 1.06c.37-.369.69-.77.96-1.193a26.61 26.61 0 0 1 3.095 2.348.75.75 0 0 0 .992 0 26.547 26.547 0 0 1 5.93-3.95.75.75 0 0 0 .42-.739 41.053 41.053 0 0 0-.39-3.114 29.925 29.925 0 0 0-5.199 2.801 2.25 2.25 0 0 1-2.514 0c-.41-.275-.826-.541-1.25-.797a6.985 6.985 0 0 1-1.084 3.45 26.503 26.503 0 0 0-1.281-.78A5.487 5.487 0 0 0 6 12v-.54Z"
                                        clip-rule="evenodd"></path>
                                </svg>
                            </span>
                            <div class="flex flex-col space-y-2">
                                <span class="font-black xs:text-2xl text-lg text-primary">آخرین مقالات و اخبار آکادمی</span>
                                <span class="font-semibold xs:text-base text-sm text-muted">
                                    با مطالعه مقالات و اخبار آکادمی لیان امیری از آخرین فعالیت‌ها، برنامه‌های حمایتی
                                    و دوره‌های آموزشی جدید مطلع شوید.
                                </span>
                            </div>
                        </div>
                        <div class="lg:w-8/12 w-full lg:mx-auto">
                            <% if (latestArticles && latestArticles.length > 0) { %>
                            <div class="grid sm:grid-cols-2 grid-cols-1 gap-5">
                                <% latestArticles.forEach(function(article) { %>
                                <div class="relative bg-background rounded-xl p-4">
                                    <div class="relative mb-3 z-20">
                                        <a href="/blog/<%= article.slug %>" class="block">
                                            <% if (article.thumbnail) { %>
                                            <img src="<%= article.thumbnail %>" class="max-w-full rounded-xl aspect-video object-cover" alt="<%= article.title %>" />
                                            <% } else { %>
                                            <div class="w-full aspect-video rounded-xl bg-secondary flex items-center justify-center">
                                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-10 h-10 text-muted/30">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.75 16.82A7.462 7.462 0 0 1 15 15.5c.71 0 1.396.098 2.046.282A.75.75 0 0 0 18 15.06v-11a.75.75 0 0 0-.546-.721A9.006 9.006 0 0 0 15 3a8.963 8.963 0 0 0-4.25 1.065V16.82ZM9.25 4.065A8.963 8.963 0 0 0 5 3c-.85 0-1.673.118-2.454.339A.75.75 0 0 0 2 4.06v11a.75.75 0 0 0 .954.721A7.506 7.506 0 0 1 5 15.5c1.579 0 3.042.487 4.25 1.32V4.065Z" />
                                                </svg>
                                            </div>
                                            <% } %>
                                        </a>
                                    </div>
                                    <div class="relative space-y-3 z-10">
                                        <h2 class="font-bold text-sm">
                                            <a href="/blog/<%= article.slug %>"
                                                class="line-clamp-2 text-foreground transition-colors hover:text-primary"><%= article.title %></a>
                                        </h2>
                                        <div class="flex items-center justify-between gap-2">
                                            <div class="flex items-center gap-2 min-w-0">
                                                <div class="flex-shrink-0 w-7 h-7 rounded-full bg-secondary border border-border flex items-center justify-center">
                                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-muted">
                                                        <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM3.751 20.105a8.25 8.25 0 0 1 16.498 0 .75.75 0 0 1-.437.695A18.683 18.683 0 0 1 12 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 0 1-.437-.695Z" clip-rule="evenodd" />
                                                    </svg>
                                                </div>
                                                <span class="line-clamp-1 font-semibold text-xs text-muted">
                                                    <%= article.author ? (article.author.displayName || 'نویسنده') : 'نویسنده' %>
                                                </span>
                                            </div>
                                            <% if (article.category) { %>
                                            <a href="/blog?category=<%= article.category.slug %>"
                                                class="flex-shrink-0 bg-primary/10 rounded-full text-primary transition-all hover:opacity-80 py-1 px-3">
                                                <span class="font-bold text-xxs"><%= article.category.title %></span>
                                            </a>
                                            <% } %>
                                        </div>
                                        <% if (article.readTime > 0) { %>
                                        <div class="flex items-center gap-1 text-muted">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                            </svg>
                                            <span class="font-semibold text-xs text-muted">زمان مطالعه:</span>
                                            <span class="font-semibold text-xs text-foreground"><%= article.readTime %> دقیقه</span>
                                        </div>
                                        <% } %>
                                    </div>
                                </div>
                                <% }); %>
                            </div>
                            <% } else { %>
                            <div class="flex items-center justify-center h-32 text-muted font-semibold text-sm">
                                مقاله‌ای منتشر نشده است.
                            </div>
                            <% } %>
                            <div class="mt-6 text-center">
                                <a href="/blog" class="inline-flex items-center gap-1 h-10 bg-secondary rounded-full font-semibold text-sm text-foreground hover:text-primary transition-colors px-6">
                                    مشاهده همه مقالات
                                </a>
                            </div>
                        </div>
                    </div>
                    <!-- end articles -->
                </div>
                <!-- end container -->
            </div>
        </main>

