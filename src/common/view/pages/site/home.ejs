                            <div class="swiper-wrapper">
                                <% latestCourses.forEach(function(course) { %>
                                <div class="swiper-slide">
                                    <%- include('../../partials/course-card', { course: course, isWishlisted: false }) %>
                                </div>
                                <% }); %>
                                <% if (!latestCourses.length) { %>
                                <div class="swiper-slide">
                                    <div class="flex items-center justify-center h-48 text-muted font-semibold text-sm">
                                        دوره‌ای منتشر نشده است.
                                    </div>
                                </div>
                                <% } %>
                            </div>

