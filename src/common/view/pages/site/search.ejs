<!-- search page -->
<div class="max-w-7xl mx-auto px-4 py-10 space-y-12">

  <!-- search bar -->
  <div class="max-w-2xl mx-auto">
    <form action="/search" method="get" class="flex items-center gap-3">
      <div class="flex items-center flex-1 min-w-0 gap-3 bg-secondary border border-border rounded-2xl px-4 py-3 focus-within:border-primary transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-muted shrink-0">
          <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd" />
        </svg>
        <input
          type="text"
          name="q"
          value="<%= q %>"
          autofocus
          placeholder="نام دوره یا مقاله..."
          class="flex-1 min-w-0 bg-transparent border-0 outline-none ring-0 text-foreground placeholder-muted text-sm font-medium"
        />
        <% if (q) { %>
        <a href="/search" class="shrink-0 text-muted hover:text-red-500 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </a>
        <% } %>
      </div>
      <button type="submit" class="shrink-0 h-12 px-5 bg-primary text-primary-foreground rounded-2xl text-sm font-semibold transition-opacity hover:opacity-80 whitespace-nowrap">
        جستجو
      </button>
    </form>
  </div>

  <% if (!q) { %>
  <!-- empty — no query -->
  <div class="text-center py-24 space-y-4">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-secondary text-muted mx-auto">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-10 h-10">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
      </svg>
    </div>
    <p class="font-bold text-lg text-foreground">چیزی جستجو کنید</p>
    <p class="text-sm text-muted">نام دوره، مقاله یا دسته‌بندی مورد نظرتان را در کادر بالا وارد کنید.</p>
  </div>

  <% } else if (total === 0) { %>
  <!-- no results -->
  <div class="text-center py-24 space-y-4">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-secondary text-muted mx-auto">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.2" stroke="currentColor" class="w-10 h-10">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 16.318A4.486 4.486 0 0 0 12.016 15a4.486 4.486 0 0 0-3.198 1.318M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0ZM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75Zm-.375 0h.008v.015h-.008V9.75Z" />
      </svg>
    </div>
    <p class="font-bold text-lg text-foreground">نتیجه‌ای یافت نشد</p>
    <p class="text-sm text-muted">برای «<span class="text-foreground font-semibold"><%= q %></span>» هیچ دوره یا مقاله‌ای پیدا نشد.</p>
    <p class="text-xs text-muted">سعی کنید کلمات کمتر یا متفاوتی استفاده کنید.</p>
  </div>

  <% } else { %>
  <!-- results summary -->
  <div class="min-w-0">
    <h1 class="font-bold text-xl text-foreground break-words">
      نتایج جستجو برای «<span class="text-primary"><%= q %></span>»
    </h1>
    <p class="text-sm text-muted mt-1"><%= total %> نتیجه یافت شد</p>
  </div>

  <% if (courses && courses.length > 0) { %>
  <!-- courses section -->
  <section class="space-y-6">
    <div class="flex items-center justify-between gap-3 flex-wrap">
      <div class="flex items-center gap-3 min-w-0">
        <div class="w-1 h-6 bg-primary rounded-full shrink-0"></div>
        <h2 class="font-bold text-lg text-foreground">دوره‌های آموزشی</h2>
        <span class="inline-flex items-center justify-center h-6 px-2.5 rounded-full bg-primary/10 text-primary text-xs font-bold shrink-0"><%= courses.length %></span>
      </div>
      <a href="/courses?q=<%= encodeURIComponent(q) %>" class="shrink-0 inline-flex items-center gap-1 text-sm font-semibold text-primary hover:opacity-80 transition-opacity">
        <span>همه دوره‌ها</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
          <path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-5 gap-y-10">
      <% courses.forEach(function(course) { %>
      <%- include('view/partials/course-card', { course, isWishlisted: false }) %>
      <% }) %>
    </div>
  </section>
  <% } %>

  <% if (articles && articles.length > 0) { %>
  <!-- articles section -->
  <section class="space-y-6">
    <div class="flex items-center justify-between gap-3 flex-wrap">
      <div class="flex items-center gap-3 min-w-0">
        <div class="w-1 h-6 bg-primary rounded-full shrink-0"></div>
        <h2 class="font-bold text-lg text-foreground">مقالات</h2>
        <span class="inline-flex items-center justify-center h-6 px-2.5 rounded-full bg-primary/10 text-primary text-xs font-bold shrink-0"><%= articles.length %></span>
      </div>
      <a href="/blog?q=<%= encodeURIComponent(q) %>" class="shrink-0 inline-flex items-center gap-1 text-sm font-semibold text-primary hover:opacity-80 transition-opacity">
        <span>همه مقالات</span>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
          <path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-5 gap-y-8">
      <% articles.forEach(function(article) { %>
      <a href="/blog/<%= article.slug %>" class="group flex flex-col bg-background border border-border rounded-2xl overflow-hidden hover:border-primary/50 hover:shadow-lg transition-all">
        <div class="relative aspect-video bg-secondary overflow-hidden">
          <% if (article.thumbnail) { %>
          <img src="<%= article.thumbnail %>" alt="<%= article.title %>" class="w-full h-full object-cover transition-transform group-hover:scale-105" />
          <% } else { %>
          <div class="w-full h-full flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-12 h-12 text-muted/30">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6v-3Z" />
            </svg>
          </div>
          <% } %>
          <% if (article.category) { %>
          <span class="absolute top-3 right-3 inline-flex items-center h-7 px-3 rounded-full bg-primary/80 text-white text-xs font-semibold backdrop-blur-sm"><%= article.category.title %></span>
          <% } %>
        </div>
        <div class="flex flex-col flex-1 p-5 space-y-3">
          <h3 class="font-bold text-sm text-foreground line-clamp-2 group-hover:text-primary transition-colors"><%= article.title %></h3>
          <% if (article.shortDescription) { %>
          <p class="text-xs text-muted line-clamp-2 flex-1"><%= article.shortDescription %></p>
          <% } %>
          <div class="flex items-center gap-4 pt-2 border-t border-border">
            <% if (article.readTime) { %>
            <div class="flex items-center gap-1 text-muted">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 0 0 0-1.5h-3.25V5Z" clip-rule="evenodd" />
              </svg>
              <span class="text-xs font-medium"><%= article.readTime %> دقیقه مطالعه</span>
            </div>
            <% } %>
            <span class="mr-auto inline-flex items-center gap-1 text-primary text-xs font-semibold">
              <span>مطالعه</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5">
                <path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd" />
              </svg>
            </span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  </section>
  <% } %>

  <% } %>
</div>
<!-- end search page -->
