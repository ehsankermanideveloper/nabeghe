<div style="max-width:860px">
  <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.25rem">
    <a href="/admin/articles" style="color:#94a3b8;text-decoration:none;font-size:.875rem">← بازگشت</a>
    <span style="color:#334155">|</span>
    <h2 style="font-size:.95rem;font-weight:700;color:#f1f5f9"><%= isEdit ? 'ویرایش مقاله' : 'ایجاد مقاله جدید' %></h2>
  </div>

  <form method="POST" action="<%= isEdit ? '/admin/api/articles/' + article.id : '/admin/api/articles' %>" class="card" id="article-form" x-data="{ tabTitle: 'fa', tabSD: 'fa' }">

    <!-- Title -->
    <div class="form-group">
      <div class="form-label">عنوان مقاله</div>
      <div class="tabs">
        <button type="button" class="tab-btn" :class="tabTitle === 'fa' ? 'active' : ''" @click="tabTitle = 'fa'">فارسی</button>
        <button type="button" class="tab-btn" :class="tabTitle === 'en' ? 'active' : ''" @click="tabTitle = 'en'">English</button>
        <button type="button" class="tab-btn" :class="tabTitle === 'ps' ? 'active' : ''" @click="tabTitle = 'ps'">پښتو</button>
      </div>
      <div x-show="tabTitle === 'fa'">
        <input type="text" name="title_fa" class="form-input" value="<%= isEdit && article.title ? article.title['fa'] || '' : '' %>" placeholder="عنوان فارسی" />
      </div>
      <div x-show="tabTitle === 'en'">
        <input type="text" name="title_en" class="form-input" dir="ltr" value="<%= isEdit && article.title ? article.title['en'] || '' : '' %>" placeholder="English title" />
      </div>
      <div x-show="tabTitle === 'ps'">
        <input type="text" name="title_ps" class="form-input" value="<%= isEdit && article.title ? article.title['ps'] || '' : '' %>" placeholder="پښتو سرلیک" />
      </div>
    </div>

    <!-- Short Description -->
    <div class="form-group">
      <div class="form-label">توضیح کوتاه</div>
      <div class="tabs">
        <button type="button" class="tab-btn" :class="tabSD === 'fa' ? 'active' : ''" @click="tabSD = 'fa'">فارسی</button>
        <button type="button" class="tab-btn" :class="tabSD === 'en' ? 'active' : ''" @click="tabSD = 'en'">English</button>
        <button type="button" class="tab-btn" :class="tabSD === 'ps' ? 'active' : ''" @click="tabSD = 'ps'">پښتو</button>
      </div>
      <div x-show="tabSD === 'fa'">
        <textarea name="shortDescription_fa" class="form-input"><%= isEdit && article.shortDescription ? article.shortDescription['fa'] || '' : '' %></textarea>
      </div>
      <div x-show="tabSD === 'en'">
        <textarea name="shortDescription_en" class="form-input" dir="ltr"><%= isEdit && article.shortDescription ? article.shortDescription['en'] || '' : '' %></textarea>
      </div>
      <div x-show="tabSD === 'ps'">
        <textarea name="shortDescription_ps" class="form-input"><%= isEdit && article.shortDescription ? article.shortDescription['ps'] || '' : '' %></textarea>
      </div>
    </div>

    <!-- Body (CKEditor) -->
    <div class="form-group">
      <div class="form-label">متن مقاله</div>

      <!-- Tab buttons (plain JS, not Alpine) -->
      <div class="tabs" id="body-tabs">
        <button type="button" class="tab-btn active" data-lang="fa" onclick="switchBodyTab('fa')">فارسی</button>
        <button type="button" class="tab-btn" data-lang="en" onclick="switchBodyTab('en')">English</button>
        <button type="button" class="tab-btn" data-lang="ps" onclick="switchBodyTab('ps')">پښتو</button>
      </div>

      <!-- Hidden inputs submitted with the form -->
      <input type="hidden" name="body_fa" id="body-input-fa" />
      <input type="hidden" name="body_en" id="body-input-en" />
      <input type="hidden" name="body_ps" id="body-input-ps" />

      <!-- Editor panels — content rendered server-side as initial data for CKEditor -->
      <div id="body-panel-fa" style="display:block">
        <div id="body-editor-fa" dir="rtl"><%- isEdit && article.body ? article.body['fa'] || '' : '' %></div>
      </div>
      <div id="body-panel-en" style="display:none">
        <div id="body-editor-en" dir="ltr"><%- isEdit && article.body ? article.body['en'] || '' : '' %></div>
      </div>
      <div id="body-panel-ps" style="display:none">
        <div id="body-editor-ps" dir="rtl"><%- isEdit && article.body ? article.body['ps'] || '' : '' %></div>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
      <div class="form-group">
        <label class="form-label">Slug (آدرس URL)</label>
        <input type="text" name="slug" class="form-input" dir="ltr" value="<%= isEdit ? article.slug : '' %>" placeholder="article-slug" />
      </div>
      <div class="form-group">
        <label class="form-label">زمان مطالعه (دقیقه)</label>
        <input type="number" name="readTime" class="form-input" value="<%= isEdit ? article.readTime : 0 %>" min="0" />
      </div>
      <div class="form-group">
        <label class="form-label">وضعیت</label>
        <select name="status" class="form-input">
          <option value="draft" <%= isEdit && article.status === 'draft' ? 'selected' : '' %>>پیش‌نویس</option>
          <option value="published" <%= isEdit && article.status === 'published' ? 'selected' : '' %>>منتشر شده</option>
          <option value="archived" <%= isEdit && article.status === 'archived' ? 'selected' : '' %>>آرشیو</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">دسته‌بندی</label>
        <select name="categoryId" class="form-input">
          <option value="">— بدون دسته‌بندی —</option>
          <% categories.forEach(function(cat) { %>
          <option value="<%= cat.id %>" <%= isEdit && article && article.categoryId === cat.id ? 'selected' : '' %>>
            <%= '　'.repeat(cat.depth) %><%= cat.depth > 0 ? '└ ' : '' %><%= cat.title['fa'] || cat.title['en'] || '' %>
          </option>
          <% }); %>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">شناسه نویسنده (ID کاربر)</label>
        <input type="number" name="authorId" class="form-input" value="<%= isEdit ? article.authorId : '' %>" placeholder="1" />
      </div>
      <div class="form-group">
        <label class="form-label">ترتیب نمایش</label>
        <input type="number" name="sortOrder" class="form-input" value="<%= isEdit ? article.sortOrder : 0 %>" />
      </div>
    </div>

    <div style="display:flex;gap:.75rem;margin-top:.5rem">
      <button type="submit" class="btn-primary"><%= isEdit ? 'ذخیره تغییرات' : 'ایجاد مقاله' %></button>
      <a href="/admin/articles" class="btn-secondary">انصراف</a>
    </div>
  </form>
</div>

<script>
(function () {
  const {
    ClassicEditor,
    Autoformat,
    AutoLink,
    BlockQuote,
    Bold,
    CodeBlock,
    Essentials,
    Heading,
    HorizontalLine,
    Indent,
    IndentBlock,
    Italic,
    Link,
    List,
    ListProperties,
    Paragraph,
    SelectAll,
    Strikethrough,
    Table,
    TableCaption,
    TableCellProperties,
    TableColumnResize,
    TableProperties,
    TableToolbar,
    TextTransformation,
    Underline,
    Undo,
  } = CKEDITOR;

  const TOOLBAR = [
    'heading', '|',
    'bold', 'italic', 'underline', 'strikethrough', '|',
    'bulletedList', 'numberedList', '|',
    'outdent', 'indent', '|',
    'blockQuote', 'codeBlock', 'insertTable', 'horizontalLine', 'link', '|',
    'undo', 'redo',
  ];

  const PLUGINS = [
    Essentials, Autoformat, AutoLink,
    Bold, Italic, Underline, Strikethrough,
    Paragraph, Heading,
    List, ListProperties,
    BlockQuote, CodeBlock,
    HorizontalLine, Link,
    Indent, IndentBlock,
    Table, TableToolbar, TableCaption, TableCellProperties, TableColumnResize, TableProperties,
    TextTransformation, SelectAll, Undo,
  ];

  const editors = {};
  let activeTab = 'fa';

  async function initEditor(lang) {
    if (editors[lang]) return;
    const el = document.getElementById('body-editor-' + lang);
    const isRtl = lang !== 'en';
    editors[lang] = await ClassicEditor.create(el, {
      plugins: PLUGINS,
      toolbar: { items: TOOLBAR, shouldNotGroupWhenFull: false },
      language: { content: isRtl ? 'ar' : 'en' },
      table: {
        contentToolbar: ['tableColumn', 'tableRow', 'mergeTableCells', 'tableCellProperties', 'tableProperties'],
      },
      list: { properties: { styles: true, startIndex: true, reversed: true } },
    });
  }

  window.switchBodyTab = function (lang) {
    // Hide current panel
    document.getElementById('body-panel-' + activeTab).style.display = 'none';
    // Update tab buttons
    document.querySelectorAll('#body-tabs .tab-btn').forEach(function (btn) {
      btn.classList.toggle('active', btn.dataset.lang === lang);
    });
    // Show new panel
    document.getElementById('body-panel-' + lang).style.display = 'block';
    activeTab = lang;
    initEditor(lang);
  };

  // Sync all editor data to hidden inputs before form submit
  document.getElementById('article-form').addEventListener('submit', function () {
    Object.entries(editors).forEach(function ([lang, editor]) {
      document.getElementById('body-input-' + lang).value = editor.getData();
    });
  });

  // Init the default (fa) editor on load
  document.addEventListener('DOMContentLoaded', function () {
    initEditor('fa');
  });
})();
</script>
