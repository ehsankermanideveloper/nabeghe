<div>
  <!-- Header -->
  <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.25rem">
    <a href="/admin/courses" style="color:#94a3b8;text-decoration:none;font-size:.875rem">← بازگشت به دوره‌ها</a>
    <span style="color:#334155">|</span>
    <h2 style="font-size:.95rem;font-weight:700;color:#f1f5f9"><%= isEdit ? 'ویرایش دوره' : 'ایجاد دوره جدید' %></h2>
  </div>

  <!-- Main Info Form -->
  <form method="POST" action="<%= isEdit ? '/admin/api/courses/' + course.id : '/admin/api/courses' %>" class="card" x-data="{ tab: 'fa', tabSD: 'fa' }" style="margin-bottom:2rem">

    <!-- Title Tabs -->
    <div class="form-group">
      <div class="form-label">عنوان دوره</div>
      <div class="tabs">
        <button type="button" class="tab-btn" :class="tab === 'fa' ? 'active' : ''" @click="tab = 'fa'">فارسی</button>
        <button type="button" class="tab-btn" :class="tab === 'en' ? 'active' : ''" @click="tab = 'en'">English</button>
        <button type="button" class="tab-btn" :class="tab === 'ps' ? 'active' : ''" @click="tab = 'ps'">پښتو</button>
      </div>
      <div x-show="tab === 'fa'"><input type="text" name="title_fa" class="form-input" value="<%= isEdit && course && course.title ? course.title['fa'] || '' : '' %>" placeholder="عنوان فارسی" /></div>
      <div x-show="tab === 'en'"><input type="text" name="title_en" class="form-input" dir="ltr" value="<%= isEdit && course && course.title ? course.title['en'] || '' : '' %>" placeholder="English title" /></div>
      <div x-show="tab === 'ps'"><input type="text" name="title_ps" class="form-input" value="<%= isEdit && course && course.title ? course.title['ps'] || '' : '' %>" placeholder="پښتو سرلیک" /></div>
    </div>

    <!-- Short Description Tabs -->
    <div class="form-group">
      <div class="form-label">توضیح کوتاه</div>
      <div class="tabs">
        <button type="button" class="tab-btn" :class="tabSD === 'fa' ? 'active' : ''" @click="tabSD = 'fa'">فارسی</button>
        <button type="button" class="tab-btn" :class="tabSD === 'en' ? 'active' : ''" @click="tabSD = 'en'">English</button>
        <button type="button" class="tab-btn" :class="tabSD === 'ps' ? 'active' : ''" @click="tabSD = 'ps'">پښتو</button>
      </div>
      <div x-show="tabSD === 'fa'"><textarea name="shortDescription_fa" class="form-input"><%= isEdit && course && course.shortDescription ? course.shortDescription['fa'] || '' : '' %></textarea></div>
      <div x-show="tabSD === 'en'"><textarea name="shortDescription_en" class="form-input" dir="ltr"><%= isEdit && course && course.shortDescription ? course.shortDescription['en'] || '' : '' %></textarea></div>
      <div x-show="tabSD === 'ps'"><textarea name="shortDescription_ps" class="form-input"><%= isEdit && course && course.shortDescription ? course.shortDescription['ps'] || '' : '' %></textarea></div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
      <div class="form-group">
        <label class="form-label">Slug (آدرس URL)</label>
        <input type="text" name="slug" class="form-input" dir="ltr" value="<%= isEdit && course ? course.slug : '' %>" />
      </div>
      <div class="form-group">
        <label class="form-label">ویدیو پیش‌نمایش (URL)</label>
        <input type="text" name="previewVideo" class="form-input" dir="ltr" value="<%= isEdit && course ? course.previewVideo || '' : '' %>" />
      </div>
      <div class="form-group">
        <label class="form-label">قیمت (تومان)</label>
        <input type="number" name="price" class="form-input" value="<%= isEdit && course ? course.price : 0 %>" min="0" />
      </div>
      <div class="form-group">
        <label class="form-label">قیمت با تخفیف (تومان)</label>
        <input type="number" name="discountPrice" class="form-input" value="<%= isEdit && course && course.discountPrice ? course.discountPrice : '' %>" min="0" />
      </div>
      <div class="form-group">
        <label class="form-label">سطح دوره</label>
        <select name="level" class="form-input">
          <option value="all_levels" <%= isEdit && course && course.level === 'all_levels' ? 'selected' : '' %>>همه سطوح</option>
          <option value="beginner" <%= isEdit && course && course.level === 'beginner' ? 'selected' : '' %>>مبتدی</option>
          <option value="intermediate" <%= isEdit && course && course.level === 'intermediate' ? 'selected' : '' %>>متوسط</option>
          <option value="advanced" <%= isEdit && course && course.level === 'advanced' ? 'selected' : '' %>>پیشرفته</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">وضعیت</label>
        <select name="status" class="form-input">
          <option value="draft" <%= isEdit && course && course.status === 'draft' ? 'selected' : '' %>>پیش‌نویس</option>
          <option value="published" <%= isEdit && course && course.status === 'published' ? 'selected' : '' %>>منتشر شده</option>
          <option value="archived" <%= isEdit && course && course.status === 'archived' ? 'selected' : '' %>>آرشیو</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">دسته‌بندی</label>
        <select name="categoryId" class="form-input">
          <option value="">— بدون دسته‌بندی —</option>
          <% categories.forEach(function(cat) { %>
          <option value="<%= cat.id %>" <%= isEdit && course && course.categoryId === cat.id ? 'selected' : '' %>>
            <%= '　'.repeat(cat.depth) %><%= cat.depth > 0 ? '└ ' : '' %><%= cat.title['fa'] || cat.title['en'] || '' %>
          </option>
          <% }); %>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">شناسه مدرس (ID کاربر)</label>
        <input type="number" name="instructorId" class="form-input" value="<%= isEdit && course ? course.instructorId : '' %>" placeholder="1" />
      </div>
      <div class="form-group">
        <label class="form-label">ترتیب نمایش</label>
        <input type="number" name="sortOrder" class="form-input" value="<%= isEdit && course ? course.sortOrder : 0 %>" />
      </div>
    </div>

    <div style="display:flex;gap:.75rem;margin-top:.5rem">
      <button type="submit" class="btn-primary"><%= isEdit ? 'ذخیره تغییرات' : 'ایجاد دوره' %></button>
      <a href="/admin/courses" class="btn-secondary">انصراف</a>
    </div>
  </form>

  <!-- Chapters & Episodes (only in edit mode) -->
  <% if (isEdit && course) { %>
  <div x-data="chaptersManager(<%= course.id %>)" x-init="init()">

    <!-- Section Header -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
      <h3 style="font-size:1rem;font-weight:700;color:#f1f5f9">سرفصل‌ها و اپیزودها</h3>
      <button type="button" class="btn-primary" @click="showAddChapter = !showAddChapter">
        + افزودن فصل
      </button>
    </div>

    <!-- Add Chapter Form -->
    <div x-show="showAddChapter" x-cloak class="card" style="margin-bottom:1rem">
      <div style="font-size:.875rem;font-weight:700;color:#f1f5f9;margin-bottom:.75rem">فصل جدید</div>
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:.75rem;margin-bottom:.75rem">
        <div>
          <div class="form-label">عنوان فارسی *</div>
          <input type="text" x-model="newChapter.title_fa" class="form-input" placeholder="نام فصل" />
        </div>
        <div>
          <div class="form-label">English</div>
          <input type="text" x-model="newChapter.title_en" class="form-input" dir="ltr" placeholder="Chapter title" />
        </div>
        <div>
          <div class="form-label">ترتیب</div>
          <input type="number" x-model="newChapter.sortOrder" class="form-input" value="0" />
        </div>
      </div>
      <div style="display:flex;gap:.5rem">
        <button type="button" class="btn-primary" @click="addChapter()" :disabled="loading">افزودن فصل</button>
        <button type="button" class="btn-secondary" @click="showAddChapter = false">انصراف</button>
      </div>
    </div>

    <!-- Loading -->
    <div x-show="loading" style="text-align:center;padding:2rem;color:#94a3b8;font-size:.875rem">در حال بارگذاری...</div>

    <!-- Chapters List -->
    <div x-show="!loading">
      <template x-if="chapters.length === 0">
        <div class="card" style="text-align:center;padding:2rem;color:#94a3b8;font-size:.875rem">
          هنوز فصلی اضافه نشده است. از دکمه «افزودن فصل» استفاده کنید.
        </div>
      </template>

      <template x-for="chapter in chapters" :key="chapter.id">
        <div class="card" style="margin-bottom:.75rem">
          <!-- Chapter Header -->
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.5rem">
            <div style="display:flex;align-items:center;gap:.75rem;flex:1">
              <button type="button" @click="chapter._open = !chapter._open" style="background:none;border:none;cursor:pointer;color:#94a3b8;padding:0;line-height:0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:1.25rem;height:1.25rem;transition:transform .2s" :style="chapter._open ? 'transform:rotate(90deg)' : ''">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                </svg>
              </button>
              <template x-if="!chapter._editing">
                <div>
                  <span style="font-weight:700;color:#f1f5f9;font-size:.9rem" x-text="chapter.title['fa'] || chapter.title['en'] || 'بدون عنوان'"></span>
                  <span style="margin-right:.5rem;color:#94a3b8;font-size:.8rem" x-text="'(' + chapter.episodes.length + ' اپیزود)'"></span>
                </div>
              </template>
              <template x-if="chapter._editing">
                <div style="display:flex;gap:.5rem;flex:1">
                  <input type="text" x-model="chapter._editTitle" class="form-input" style="max-width:250px" />
                  <button type="button" class="btn-success" style="padding:.3rem .6rem;font-size:.8rem" @click="saveChapter(chapter)">ذخیره</button>
                  <button type="button" class="btn-secondary" style="padding:.3rem .6rem;font-size:.8rem" @click="chapter._editing = false">لغو</button>
                </div>
              </template>
            </div>
            <div style="display:flex;gap:.5rem">
              <button type="button" class="btn-secondary" style="padding:.3rem .6rem;font-size:.75rem" @click="chapter._editing = true; chapter._editTitle = chapter.title['fa'] || ''">ویرایش</button>
              <button type="button" class="btn-danger" style="padding:.3rem .6rem;font-size:.75rem" @click="deleteChapter(chapter.id)">حذف</button>
            </div>
          </div>

          <!-- Episodes List (collapsible) -->
          <div x-show="chapter._open !== false" style="margin-top:.75rem;padding-top:.75rem;border-top:1px solid #334155">
            <template x-for="ep in chapter.episodes" :key="ep.id">
              <div style="display:flex;align-items:center;gap:.75rem;padding:.5rem .75rem;background:#0f172a;border-radius:.5rem;margin-bottom:.375rem">
                <div style="flex:1">
                  <span style="font-size:.85rem;font-weight:600;color:#f1f5f9" x-text="ep.title['fa'] || ep.title['en'] || 'بدون عنوان'"></span>
                  <span style="margin-right:.5rem">
                    <span :class="ep.status === 'published' ? 'badge badge-green' : 'badge badge-yellow'" style="font-size:.7rem" x-text="ep.status === 'published' ? 'منتشر' : 'پیش‌نویس'"></span>
                  </span>
                  <span x-show="ep.isFree" class="badge badge-blue" style="font-size:.7rem">رایگان</span>
                  <span x-show="ep.videoDuration" style="color:#64748b;font-size:.75rem;margin-right:.25rem" x-text="ep.videoDuration ? Math.floor(ep.videoDuration/60) + ' دقیقه' : ''"></span>
                </div>
                <div style="display:flex;gap:.375rem">
                  <button type="button" class="btn-secondary" style="padding:.25rem .5rem;font-size:.75rem" @click="openEditEpisode(ep, chapter.id)">ویرایش</button>
                  <button type="button" class="btn-danger" style="padding:.25rem .5rem;font-size:.75rem" @click="deleteEpisode(ep.id)">حذف</button>
                </div>
              </div>
            </template>

            <!-- Add Episode Button -->
            <button type="button" class="btn-secondary" style="width:100%;margin-top:.5rem;justify-content:center;font-size:.8rem" @click="openAddEpisode(chapter.id)">
              + افزودن اپیزود به این فصل
            </button>
          </div>
        </div>
      </template>
    </div>

    <!-- Episode Modal/Panel -->
    <div x-show="episodePanel.show" x-cloak style="position:fixed;inset:0;z-index:100;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.7)">
      <div style="background:#1e293b;border:1px solid #334155;border-radius:1rem;width:90%;max-width:700px;max-height:90vh;overflow-y:auto;padding:1.5rem">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem">
          <h4 style="font-weight:700;color:#f1f5f9" x-text="episodePanel.isEdit ? 'ویرایش اپیزود' : 'اپیزود جدید'"></h4>
          <button type="button" @click="episodePanel.show = false" style="background:none;border:none;cursor:pointer;color:#94a3b8;padding:0;line-height:0">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:1.25rem;height:1.25rem"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>
          </button>
        </div>

        <!-- Title tabs -->
        <div x-data="{ epTab: 'fa' }">
          <div class="form-group">
            <div class="form-label">عنوان اپیزود</div>
            <div class="tabs">
              <button type="button" class="tab-btn" :class="epTab==='fa'?'active':''" @click="epTab='fa'">فارسی</button>
              <button type="button" class="tab-btn" :class="epTab==='en'?'active':''" @click="epTab='en'">English</button>
              <button type="button" class="tab-btn" :class="epTab==='ps'?'active':''" @click="epTab='ps'">پښتو</button>
            </div>
            <div x-show="epTab==='fa'"><input type="text" x-model="episodePanel.form.title_fa" class="form-input" placeholder="عنوان فارسی" /></div>
            <div x-show="epTab==='en'"><input type="text" x-model="episodePanel.form.title_en" class="form-input" dir="ltr" placeholder="English title" /></div>
            <div x-show="epTab==='ps'"><input type="text" x-model="episodePanel.form.title_ps" class="form-input" placeholder="پښتو سرلیک" /></div>
          </div>

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem">
            <div class="form-group">
              <label class="form-label">Slug</label>
              <input type="text" x-model="episodePanel.form.slug" class="form-input" dir="ltr" />
            </div>
            <div class="form-group">
              <label class="form-label">وضعیت</label>
              <select x-model="episodePanel.form.status" class="form-input">
                <option value="draft">پیش‌نویس</option>
                <option value="published">منتشر</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">URL ویدیو</label>
              <input type="text" x-model="episodePanel.form.videoUrl" class="form-input" dir="ltr" placeholder="https://..." />
            </div>
            <div class="form-group">
              <label class="form-label">مدت ویدیو (ثانیه)</label>
              <input type="number" x-model="episodePanel.form.videoDuration" class="form-input" min="0" />
            </div>
            <div class="form-group">
              <label class="form-label">URL فایل ضمیمه</label>
              <input type="text" x-model="episodePanel.form.attachmentUrl" class="form-input" dir="ltr" />
            </div>
            <div class="form-group">
              <label class="form-label">ترتیب نمایش</label>
              <input type="number" x-model="episodePanel.form.sortOrder" class="form-input" min="0" />
            </div>
          </div>

          <div style="display:flex;align-items:center;gap:1.5rem;margin-bottom:1rem">
            <label style="display:flex;align-items:center;gap:.5rem;cursor:pointer;font-size:.875rem;color:#f1f5f9">
              <input type="checkbox" x-model="episodePanel.form.isFree" style="width:1rem;height:1rem" />
              اپیزود رایگان (بدون نیاز به ثبت‌نام)
            </label>
          </div>

          <div style="display:flex;gap:.75rem">
            <button type="button" class="btn-primary" @click="saveEpisode()" :disabled="loading" x-text="episodePanel.isEdit ? 'ذخیره تغییرات' : 'افزودن اپیزود'"></button>
            <button type="button" class="btn-secondary" @click="episodePanel.show = false">انصراف</button>
          </div>
        </div>
      </div>
    </div>

  </div>

  <script>
  function chaptersManager(courseId) {
    return {
      courseId: courseId,
      chapters: [],
      loading: false,
      showAddChapter: false,
      newChapter: { title_fa: '', title_en: '', sortOrder: 0 },
      episodePanel: {
        show: false,
        isEdit: false,
        episodeId: null,
        chapterId: null,
        form: { title_fa: '', title_en: '', title_ps: '', slug: '', videoUrl: '', videoDuration: '', attachmentUrl: '', sortOrder: 0, isFree: false, status: 'draft' }
      },

      async init() {
        await this.loadChapters();
      },

      async loadChapters() {
        this.loading = true;
        try {
          const r = await fetch('/admin/api/courses/' + this.courseId + '/chapters');
          const data = await r.json();
          this.chapters = data.map(ch => ({ ...ch, _open: true, _editing: false, _editTitle: '' }));
        } finally {
          this.loading = false;
        }
      },

      async addChapter() {
        if (!this.newChapter.title_fa.trim()) return;
        this.loading = true;
        try {
          await fetch('/admin/api/courses/' + this.courseId + '/chapters', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(this.newChapter)
          });
          this.newChapter = { title_fa: '', title_en: '', sortOrder: 0 };
          this.showAddChapter = false;
          await this.loadChapters();
        } finally {
          this.loading = false;
        }
      },

      async saveChapter(chapter) {
        await fetch('/admin/api/chapters/' + chapter.id, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ title_fa: chapter._editTitle })
        });
        chapter._editing = false;
        await this.loadChapters();
      },

      async deleteChapter(id) {
        if (!confirm('این فصل و تمام اپیزودهایش حذف می‌شوند. ادامه می‌دهید؟')) return;
        await fetch('/admin/api/chapters/' + id, { method: 'DELETE' });
        await this.loadChapters();
      },

      openAddEpisode(chapterId) {
        this.episodePanel = {
          show: true, isEdit: false, episodeId: null, chapterId: chapterId,
          form: { title_fa: '', title_en: '', title_ps: '', slug: '', videoUrl: '', videoDuration: '', attachmentUrl: '', sortOrder: 0, isFree: false, status: 'draft' }
        };
      },

      openEditEpisode(ep, chapterId) {
        this.episodePanel = {
          show: true, isEdit: true, episodeId: ep.id, chapterId: chapterId,
          form: {
            title_fa: ep.title['fa'] || '', title_en: ep.title['en'] || '', title_ps: ep.title['ps'] || '',
            slug: ep.slug || '', videoUrl: ep.videoUrl || '', videoDuration: ep.videoDuration || '',
            attachmentUrl: ep.attachmentUrl || '', sortOrder: ep.sortOrder || 0,
            isFree: ep.isFree || false, status: ep.status || 'draft'
          }
        };
      },

      async saveEpisode() {
        const payload = { ...this.episodePanel.form, chapterId: this.episodePanel.chapterId };
        this.loading = true;
        try {
          if (this.episodePanel.isEdit) {
            await fetch('/admin/api/episodes/' + this.episodePanel.episodeId, {
              method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
            });
          } else {
            await fetch('/admin/api/courses/' + this.courseId + '/episodes', {
              method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
            });
          }
          this.episodePanel.show = false;
          await this.loadChapters();
        } finally {
          this.loading = false;
        }
      },

      async deleteEpisode(id) {
        if (!confirm('این اپیزود حذف شود؟')) return;
        await fetch('/admin/api/episodes/' + id, { method: 'DELETE' });
        await this.loadChapters();
      }
    };
  }
  </script>
  <% } %>
</div>
