<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'مدیریت' %> — پنل ادمین</title>
  <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg" />
  <link rel="stylesheet" href="/assets/css/fonts.css" />
  <link rel="stylesheet" href="/assets/css/app.css" />
  <% if (locals.useCkeditor) { %>
  <link rel="stylesheet" href="https://cdn.ckeditor.com/ckeditor5/43.3.1/ckeditor5.css" />
  <style>
    /* CKEditor 5 dark theme for admin panel */
    :root {
      --ck-color-base-background: #0f172a;
      --ck-color-base-border: #334155;
      --ck-color-base-text: #f1f5f9;
      --ck-color-toolbar-background: #1e293b;
      --ck-color-toolbar-border-color: #334155;
      --ck-color-button-default-background: transparent;
      --ck-color-button-default-hover-background: #334155;
      --ck-color-button-default-active-background: #334155;
      --ck-color-button-on-background: rgba(99,102,241,.2);
      --ck-color-button-on-hover-background: rgba(99,102,241,.3);
      --ck-color-button-on-color: #a5b4fc;
      --ck-color-split-button-hover-background: #334155;
      --ck-color-input-background: #0f172a;
      --ck-color-input-border: #334155;
      --ck-color-input-text: #f1f5f9;
      --ck-color-input-disabled-background: #1e293b;
      --ck-color-dropdown-panel-background: #1e293b;
      --ck-color-dropdown-panel-border: #334155;
      --ck-color-list-background: #1e293b;
      --ck-color-list-button-hover-background: #334155;
      --ck-color-list-button-on-background: rgba(99,102,241,.2);
      --ck-color-list-button-on-background-focus: rgba(99,102,241,.3);
      --ck-color-list-button-on-text: #a5b4fc;
      --ck-color-panel-background: #1e293b;
      --ck-color-panel-border: #334155;
      --ck-color-tooltip-background: #334155;
      --ck-color-tooltip-text: #f1f5f9;
      --ck-color-table-focused-cell-background: rgba(99,102,241,.1);
      --ck-color-editable-blur-selection-background: rgba(99,102,241,.15);
      --ck-color-focus-border: #6366f1;
      --ck-color-focus-outer-shadow: rgba(99,102,241,.25);
      --ck-color-shadow-inner: transparent;
      --ck-color-shadow-drop: rgba(0,0,0,.5);
      --ck-border-radius: .5rem;
    }
    .ck.ck-editor { border: 1px solid #334155 !important; border-radius: .5rem !important; overflow: hidden; }
    .ck.ck-editor__main>.ck-editor__editable { background: #0f172a !important; color: #f1f5f9 !important; min-height: 320px; font-family: "YekanBakh","Tahoma",sans-serif; font-size: .9rem; line-height: 1.8; }
    .ck.ck-editor__main>.ck-editor__editable:not(.ck-focused) { border-color: transparent !important; }
    .ck.ck-editor__main>.ck-editor__editable.ck-focused { border-color: #6366f1 !important; }
    .ck.ck-toolbar { background: #1e293b !important; border-bottom: 1px solid #334155 !important; padding: .25rem .5rem !important; }
    .ck.ck-toolbar__separator { background: #334155 !important; }
    .ck.ck-button .ck-icon { color: #94a3b8; }
    .ck.ck-button:hover .ck-icon, .ck.ck-button.ck-on .ck-icon { color: #f1f5f9; }
    .ck-rounded-corners .ck.ck-editor__top .ck-sticky-panel .ck-toolbar { border-radius: 0 !important; }
    .ck.ck-labeled-field-view>.ck-labeled-field-view__input-wrapper>.ck-input { color: #f1f5f9; }
    /* Content area text styles */
    .ck-content h2,.ck-content h3,.ck-content h4 { color: #f1f5f9; margin: 1rem 0 .5rem; }
    .ck-content p { margin-bottom: .75rem; }
    .ck-content a { color: #a5b4fc; }
    .ck-content blockquote { border-right: 4px solid #6366f1; padding: .5rem 1rem; color: #94a3b8; margin: .75rem 0; background: rgba(99,102,241,.08); }
    .ck-content pre { background: #1e293b; border: 1px solid #334155; border-radius: .375rem; padding: .75rem 1rem; font-size: .85rem; }
    .ck-content ul,.ck-content ol { padding-right: 1.5rem; margin-bottom: .75rem; }
    .ck-content table { border-collapse: collapse; width: 100%; }
    .ck-content table td,.ck-content table th { border: 1px solid #334155; padding: .5rem .75rem; }
    .ck-content table th { background: #1e293b; }
  </style>
  <% } %>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:#0f172a;color:#f1f5f9;min-height:100vh;display:flex}
    [x-cloak]{display:none!important}
    .admin-sidebar{width:240px;min-height:100vh;background:#1e293b;border-left:1px solid #334155;display:flex;flex-direction:column;position:fixed;right:0;top:0;bottom:0;z-index:50}
    .admin-sidebar-logo{padding:1.25rem 1rem;border-bottom:1px solid #334155;display:flex;align-items:center;gap:.75rem}
    .admin-sidebar-logo svg{color:#6366f1;width:1.75rem;height:1.75rem;flex-shrink:0}
    .admin-sidebar-logo span{font-size:.95rem;font-weight:700;color:#f1f5f9}
    .admin-nav{padding:.75rem 0;flex:1;overflow-y:auto}
    .admin-nav a{display:flex;align-items:center;gap:.75rem;padding:.625rem 1rem;color:#94a3b8;text-decoration:none;font-size:.875rem;transition:background .15s,color .15s;border-radius:0}
    .admin-nav a:hover,.admin-nav a.active{background:rgba(99,102,241,.15);color:#a5b4fc}
    .admin-nav a svg{width:1.125rem;height:1.125rem;flex-shrink:0}
    .admin-sidebar-footer{padding:.75rem 1rem;border-top:1px solid #334155}
    .admin-main{margin-right:240px;flex:1;display:flex;flex-direction:column;min-height:100vh}
    .admin-topbar{background:#1e293b;border-bottom:1px solid #334155;padding:.875rem 1.5rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:40}
    .admin-topbar h1{font-size:1rem;font-weight:700;color:#f1f5f9}
    .admin-content{padding:1.5rem;flex:1}
    .btn-primary{display:inline-flex;align-items:center;gap:.5rem;background:#6366f1;color:#fff;border:none;border-radius:.5rem;padding:.5rem 1rem;font-size:.875rem;font-weight:600;cursor:pointer;text-decoration:none;transition:opacity .15s}
    .btn-primary:hover{opacity:.85}
    .btn-secondary{display:inline-flex;align-items:center;gap:.5rem;background:#334155;color:#f1f5f9;border:none;border-radius:.5rem;padding:.5rem 1rem;font-size:.875rem;font-weight:600;cursor:pointer;text-decoration:none;transition:background .15s}
    .btn-secondary:hover{background:#475569}
    .btn-danger{display:inline-flex;align-items:center;gap:.5rem;background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.3);border-radius:.5rem;padding:.4rem .75rem;font-size:.8rem;font-weight:600;cursor:pointer;text-decoration:none;transition:background .15s}
    .btn-danger:hover{background:rgba(239,68,68,.25)}
    .btn-success{display:inline-flex;align-items:center;gap:.5rem;background:rgba(34,197,94,.15);color:#4ade80;border:1px solid rgba(34,197,94,.3);border-radius:.5rem;padding:.4rem .75rem;font-size:.8rem;font-weight:600;cursor:pointer;transition:background .15s}
    .btn-success:hover{background:rgba(34,197,94,.25)}
    .card{background:#1e293b;border:1px solid #334155;border-radius:.75rem;padding:1.25rem}
    .table-wrap{background:#1e293b;border:1px solid #334155;border-radius:.75rem;overflow:hidden}
    table{width:100%;border-collapse:collapse}
    th{background:#0f172a;color:#94a3b8;font-size:.75rem;font-weight:600;padding:.625rem 1rem;text-align:right;white-space:nowrap}
    td{padding:.75rem 1rem;border-top:1px solid #1e293b;color:#f1f5f9;font-size:.875rem;vertical-align:middle}
    tr:hover td{background:rgba(99,102,241,.05)}
    .badge{display:inline-flex;align-items:center;padding:.2rem .6rem;border-radius:9999px;font-size:.75rem;font-weight:600}
    .badge-green{background:rgba(34,197,94,.15);color:#4ade80}
    .badge-yellow{background:rgba(234,179,8,.15);color:#facc15}
    .badge-red{background:rgba(239,68,68,.15);color:#f87171}
    .badge-gray{background:rgba(100,116,139,.15);color:#94a3b8}
    .badge-blue{background:rgba(59,130,246,.15);color:#60a5fa}
    .form-group{margin-bottom:1rem}
    .form-label{display:block;font-size:.8rem;color:#94a3b8;margin-bottom:.375rem;font-weight:500}
    .form-input{width:100%;background:#0f172a;border:1px solid #334155;border-radius:.5rem;padding:.625rem .875rem;color:#f1f5f9;font-size:.875rem;font-family:inherit;transition:border-color .15s}
    .form-input:focus{outline:none;border-color:#6366f1}
    select.form-input{cursor:pointer}
    .form-input option{background:#1e293b}
    textarea.form-input{resize:vertical;min-height:100px}
    .tabs{display:flex;gap:.25rem;margin-bottom:.75rem;border-bottom:1px solid #334155;padding-bottom:.5rem}
    .tab-btn{padding:.375rem .75rem;border-radius:.375rem .375rem 0 0;font-size:.8rem;font-weight:600;cursor:pointer;border:none;background:transparent;color:#94a3b8;transition:color .15s,background .15s}
    .tab-btn.active,.tab-btn[aria-selected="true"]{background:rgba(99,102,241,.2);color:#a5b4fc}
    .tab-panel{display:none}.tab-panel.active{display:block}
    .pagination{display:flex;gap:.375rem;align-items:center;margin-top:1rem;justify-content:center}
    .page-btn{display:inline-flex;align-items:center;justify-content:center;min-width:2rem;height:2rem;border-radius:.375rem;font-size:.8rem;font-weight:600;text-decoration:none;color:#94a3b8;border:1px solid #334155;background:#1e293b;transition:all .15s;padding:0 .5rem}
    .page-btn:hover{border-color:#6366f1;color:#a5b4fc}
    .page-btn.active{background:#6366f1;color:#fff;border-color:#6366f1}
    .stat-card{background:#1e293b;border:1px solid #334155;border-radius:.75rem;padding:1.25rem;display:flex;flex-direction:column;gap:.5rem}
    .stat-value{font-size:1.75rem;font-weight:800;color:#f1f5f9}
    .stat-label{font-size:.8rem;color:#94a3b8;font-weight:500}
    .alert{padding:.75rem 1rem;border-radius:.5rem;font-size:.875rem;margin-bottom:1rem}
    .alert-info{background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.3);color:#93c5fd}
  </style>
  <% if (locals.useCkeditor) { %>
  <script src="https://cdn.ckeditor.com/ckeditor5/43.3.1/ckeditor5.umd.js"></script>
  <% } %>
</head>
<body>
  <!-- Sidebar -->
  <aside class="admin-sidebar">
    <div class="admin-sidebar-logo">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0H3" />
      </svg>
      <span>پنل مدیریت</span>
    </div>
    <nav class="admin-nav">
      <a href="/admin" class="<%= typeof pageTitle !== 'undefined' && pageTitle === 'داشبورد مدیریت' ? 'active' : '' %>">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
        </svg>
        داشبورد
      </a>
      <a href="/admin/users" class="<%= typeof pageTitle !== 'undefined' && pageTitle === 'مدیریت کاربران' ? 'active' : '' %>">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
        </svg>
        کاربران
      </a>
      <a href="/admin/courses" class="<%= typeof pageTitle !== 'undefined' && (pageTitle === 'مدیریت دوره‌ها' || pageTitle === 'ایجاد دوره جدید' || pageTitle === 'ویرایش دوره') ? 'active' : '' %>">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.627 48.627 0 0 1 12 20.904a48.627 48.627 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.57 50.57 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
        </svg>
        دوره‌ها
      </a>
      <a href="/admin/articles" class="<%= typeof pageTitle !== 'undefined' && (pageTitle === 'مدیریت مقالات' || pageTitle === 'ایجاد مقاله جدید' || pageTitle === 'ویرایش مقاله') ? 'active' : '' %>">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 0 1-2.25 2.25M16.5 7.5V18a2.25 2.25 0 0 0 2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 0 0 2.25 2.25h13.5M6 7.5h3v3H6v-3Z" />
        </svg>
        مقالات
      </a>
      <a href="/admin/categories" class="<%= typeof pageTitle !== 'undefined' && pageTitle === 'مدیریت دسته‌بندی‌ها' ? 'active' : '' %>">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z" />
        </svg>
        دسته‌بندی‌ها
      </a>
      <a href="/admin/comments" class="<%= typeof pageTitle !== 'undefined' && pageTitle === 'مدیریت دیدگاه‌ها' ? 'active' : '' %>">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
        </svg>
        دیدگاه‌ها
      </a>
      <a href="/admin/enrollments" class="<%= typeof pageTitle !== 'undefined' && pageTitle === 'مدیریت ثبت‌نام‌ها' ? 'active' : '' %>">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0ZM4 19.235v-.11a6.375 6.375 0 0 1 12.75 0v.109A12.318 12.318 0 0 1 10.374 21c-2.331 0-4.512-.645-6.374-1.766Z" />
        </svg>
        ثبت‌نام‌ها
      </a>
    </nav>
    <div class="admin-sidebar-footer">
      <a href="/" style="display:flex;align-items:center;gap:.5rem;color:#94a3b8;text-decoration:none;font-size:.8rem;transition:color .15s" onmouseover="this.style.color='#f1f5f9'" onmouseout="this.style.color='#94a3b8'">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:1rem;height:1rem">
          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
        </svg>
        بازگشت به سایت
      </a>
    </div>
  </aside>

  <!-- Main -->
  <div class="admin-main">
    <header class="admin-topbar">
      <h1><%= typeof pageTitle !== 'undefined' ? pageTitle : 'مدیریت' %></h1>
      <form method="POST" action="/auth/logout" style="margin:0">
        <button type="submit" style="display:inline-flex;align-items:center;gap:.5rem;background:rgba(239,68,68,.15);color:#f87171;border:1px solid rgba(239,68,68,.3);border-radius:.5rem;padding:.4rem .75rem;font-size:.8rem;font-weight:600;cursor:pointer;font-family:inherit;transition:background .15s" onmouseover="this.style.background='rgba(239,68,68,.25)'" onmouseout="this.style.background='rgba(239,68,68,.15)'">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:1rem;height:1rem">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15m-3 0-3-3m0 0 3-3m-3 3H15" />
          </svg>
          خروج
        </button>
      </form>
    </header>
    <main class="admin-content">
      <%- body %>
    </main>
  </div>

  <script src="/assets/js/dependencies/alpinejs.min.js" defer></script>
</body>
</html>
