<main class="flex-auto py-5">
  <div class="max-w-7xl space-y-14 px-4 mx-auto">
    <div class="grid md:grid-cols-12 grid-cols-1 items-start gap-5">
      <div class="lg:col-span-3 md:col-span-4 md:sticky md:top-24">
        <%- include('../../partials/profile/_sidebar', { activeRoute: 'financial', user, csrfToken }) %>
      </div>

      <div class="lg:col-span-9 md:col-span-8">
        <div class="space-y-10">
          <div class="space-y-5">
            <!-- section:title -->
            <div class="flex items-center gap-3">
              <div class="flex items-center gap-1">
                <div class="w-1 h-1 bg-foreground rounded-full"></div>
                <div class="w-2 h-2 bg-foreground rounded-full"></div>
              </div>
              <div class="font-black text-foreground"><%= t('profile_transactions') %></div>
            </div>
            <!-- end section:title -->

            <% if (transactions.length === 0) { %>
            <div class="flex flex-col items-center justify-center py-16 text-center">
              <img src="/assets/images/theme/empty.svg" class="w-full max-w-xs opacity-35 mb-8" alt="..." />
              <p class="text-muted text-sm"><%= t('profile_no_transactions') %></p>
            </div>
            <% } else { %>

            <div class="relative overflow-x-auto">
              <table class="w-full text-sm text-right">
                <thead class="text-xs text-muted uppercase bg-background border-b border-border">
                  <tr>
                    <th class="whitespace-nowrap p-5"><%= t('tx_tracking_code') %></th>
                    <th class="whitespace-nowrap p-5"><%= t('tx_status') %></th>
                    <th class="whitespace-nowrap p-5"><%= t('tx_description') %></th>
                    <th class="whitespace-nowrap p-5"><%= t('tx_amount') %></th>
                    <th class="whitespace-nowrap p-5"><%= t('tx_date') %></th>
                  </tr>
                </thead>
                <tbody>
                  <% transactions.forEach(function(tx) { %>
                  <tr class="odd:bg-secondary even:bg-background">
                    <td class="p-5">
                      <div class="font-black text-sm text-foreground"><%= tx.trackingCode %></div>
                    </td>
                    <td class="p-5">
                      <% if (tx.status === 'success') { %>
                      <div class="flex items-center gap-2">
                        <div class="flex-shrink-0 rounded-full bg-green-500/20 p-1">
                          <div class="h-1.5 w-1.5 rounded-full bg-green-500"></div>
                        </div>
                        <span class="font-bold text-green-500"><%= t('label_success') %></span>
                      </div>
                      <% } else if (tx.status === 'failed') { %>
                      <div class="flex items-center gap-2">
                        <div class="flex-shrink-0 rounded-full bg-red-500/20 p-1">
                          <div class="h-1.5 w-1.5 rounded-full bg-red-500"></div>
                        </div>
                        <span class="font-bold text-red-500"><%= t('label_failed') %></span>
                      </div>
                      <% } else { %>
                      <div class="flex items-center gap-2">
                        <div class="flex-shrink-0 rounded-full bg-yellow-500/20 p-1">
                          <div class="h-1.5 w-1.5 rounded-full bg-yellow-500"></div>
                        </div>
                        <span class="font-bold text-yellow-500"><%= t('label_pending') %></span>
                      </div>
                      <% } %>
                    </td>
                    <td class="p-5">
                      <div class="flex flex-col items-start gap-1 w-36">
                        <span class="font-bold text-xs text-muted"><%= tx.type || t('label_transaction') %></span>
                        <span class="font-black text-sm text-foreground line-clamp-1"><%= tx.description %></span>
                      </div>
                    </td>
                    <td class="p-5">
                      <div class="flex items-center gap-1">
                        <span class="font-black text-sm text-foreground"><%= tx.amount.toLocaleString('fa-IR') %></span>
                        <span class="text-xs text-muted"><%= t('label_currency') %></span>
                      </div>
                    </td>
                    <td class="p-5">
                      <div class="text-xs text-muted whitespace-nowrap"><%= tx.createdAt %></div>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>
