<main class="flex-auto py-5">
  <div class="max-w-7xl space-y-14 px-4 mx-auto">
    <div class="grid md:grid-cols-12 grid-cols-1 items-start gap-5">
      <div class="lg:col-span-3 md:col-span-4 md:sticky md:top-24">
        <%- include('../../partials/profile/_sidebar', { activeRoute: 'edit', user, csrfToken }) %>
      </div>

      <div class="lg:col-span-9 md:col-span-8">
        <div class="space-y-10">
          <div class="space-y-5">
            <!-- section:title -->
            <div class="flex items-center gap-3">
              <div class="flex items-center gap-1">
                <div class="w-1 h-1 bg-foreground rounded-full"></div>
                <div class="w-2 h-2 bg-foreground rounded-full"></div>
              </div>
              <div class="font-black text-foreground">ویرایش پروفایل</div>
            </div>
            <!-- end section:title -->

            <!-- tabs container -->
            <div class="space-y-5" x-data="{ activeTab: 'tabOne' }">
              <!-- tabs:list-container -->
              <div class="relative overflow-x-auto">
                <!-- tabs:list -->
                <ul class="inline-flex gap-2 bg-secondary border border-border rounded-full p-1">
                  <!-- tabs:list:item -->
                  <li>
                    <button type="button"
                      class="flex items-center gap-x-2 w-full relative rounded-full py-2 px-4"
                      x-bind:class="activeTab === 'tabOne' ? 'text-foreground bg-background' : 'text-muted'"
                      x-on:click="activeTab = 'tabOne'">
                      <!-- active icon -->
                      <span x-show="activeTab === 'tabOne'">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                          <path d="M16.7574 2.99677L9.29145 10.4627L9.29886 14.7098L13.537 14.7024L21 7.23941V19.9968C21 20.5491 20.5523 20.9968 20 20.9968H4C3.44772 20.9968 3 20.5491 3 19.9968V3.99677C3 3.44448 3.44772 2.99677 4 2.99677H16.7574ZM20.4853 2.09727L21.8995 3.51149L12.7071 12.7039L11.2954 12.7063L11.2929 11.2897L20.4853 2.09727Z" />
                        </svg>
                      </span><!-- end active icon -->
                      <!-- inactive icon -->
                      <span x-show="activeTab !== 'tabOne'">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                          <path d="M16.7574 2.99677L14.7574 4.99677H5V18.9968H19V9.23941L21 7.23941V19.9968C21 20.5491 20.5523 20.9968 20 20.9968H4C3.44772 20.9968 3 20.5491 3 19.9968V3.99677C3 3.44448 3.44772 2.99677 4 2.99677H16.7574ZM20.4853 2.09727L21.8995 3.51149L12.7071 12.7039L11.2954 12.7063L11.2929 11.2897L20.4853 2.09727Z" />
                        </svg>
                      </span><!-- end inactive icon -->
                      <span class="font-semibold text-sm whitespace-nowrap">اطلاعات حساب</span>
                    </button>
                  </li><!-- end tabs:list:item -->

                  <!-- tabs:list:item -->
                  <li>
                    <button type="button"
                      class="flex items-center gap-x-2 w-full relative rounded-full py-2 px-4"
                      x-bind:class="activeTab === 'tabTwo' ? 'text-foreground bg-background' : 'text-muted'"
                      x-on:click="activeTab = 'tabTwo'">
                      <!-- active icon -->
                      <span x-show="activeTab === 'tabTwo'">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                          <path d="M6 2H18C18.5523 2 19 2.44772 19 3V21C19 21.5523 18.5523 22 18 22H6C5.44772 22 5 21.5523 5 21V3C5 2.44772 5.44772 2 6 2ZM12 17C11.4477 17 11 17.4477 11 18C11 18.5523 11.4477 19 12 19C12.5523 19 13 18.5523 13 18C13 17.4477 12.5523 17 12 17Z" />
                        </svg>
                      </span><!-- end active icon -->
                      <!-- inactive icon -->
                      <span x-show="activeTab !== 'tabTwo'">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                          <path d="M7 4V20H17V4H7ZM6 2H18C18.5523 2 19 2.44772 19 3V21C19 21.5523 18.5523 22 18 22H6C5.44772 22 5 21.5523 5 21V3C5 2.44772 5.44772 2 6 2ZM12 17C12.5523 17 13 17.4477 13 18C13 18.5523 12.5523 19 12 19C11.4477 19 11 18.5523 11 18C11 17.4477 11.4477 17 12 17Z" />
                        </svg>
                      </span><!-- end inactive icon -->
                      <span class="font-semibold text-sm whitespace-nowrap">شماره موبایل</span>
                    </button>
                  </li><!-- end tabs:list:item -->

                  <!-- tabs:list:item -->
                </ul><!-- end tabs:list -->
              </div><!-- end tabs:list-container -->

              <!-- tabs:contents -->
              <div class="bg-background rounded-3xl p-5">
                <!-- tabs:contents:tabOne -->
                <div class="space-y-5" x-show="activeTab === 'tabOne'">
                  <div class="flex items-center gap-3">
                    <div class="flex items-center gap-1">
                      <div class="w-1 h-1 bg-foreground rounded-full"></div>
                      <div class="w-2 h-2 bg-foreground rounded-full"></div>
                    </div>
                    <div class="font-black text-foreground">اطلاعات حساب</div>
                  </div>

                  <form x-data="profileInfoData()" x-on:submit.prevent="submit()" class="space-y-5">
                    <div class="grid sm:grid-cols-2 gap-5">
                      <div class="space-y-1">
                        <label for="fullname" class="font-medium text-xs text-muted">نام و نام خانوادگی (فارسی)</label>
                        <input type="text" id="fullname" x-model="displayName"
                          class="form-input w-full h-11 !ring-0 !ring-offset-0 bg-secondary border-border focus:border-border rounded-xl text-sm text-foreground px-5" />
                      </div>
                    </div>
                    <div class="flex items-center gap-3">
                      <div class="flex items-center gap-1">
                        <div class="w-1 h-1 bg-foreground rounded-full"></div>
                        <div class="w-2 h-2 bg-foreground rounded-full"></div>
                      </div>
                      <div class="font-black text-foreground">اطلاعات فردی</div>
                    </div>
                    <div class="space-y-1" x-data="jalaliPicker('<%= user.birthday || '' %>')" x-init="build()">
                      <label class="font-medium text-xs text-muted">تاریخ تولد</label>
                      <input type="hidden" name="birthday" x-bind:value="value" />
                      <div class="relative">

                        <!-- trigger -->
                        <button type="button" x-on:click="toggle()"
                          class="flex items-center w-full h-11 relative bg-secondary border border-border rounded-xl font-semibold text-xs text-right text-foreground px-3">
                          <span class="line-clamp-1" x-text="display || 'انتخاب تاریخ تولد'"></span>
                          <span class="absolute left-3 pointer-events-none transition-transform" x-bind:class="open ? 'rotate-180' : ''">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                            </svg>
                          </span>
                        </button>

                        <!-- popup -->
                        <div x-show="open" x-on:click.away="open = false"
                          class="absolute right-0 top-full mt-2 z-40 bg-background border border-border rounded-2xl shadow-2xl p-4"
                          style="width:304px">

                          <!-- ═══ view: cal ═══ -->
                          <div x-show="view === 'cal'">
                            <div class="flex items-center justify-between mb-3">
                              <button type="button" x-on:click="prevMonth()" style="order:1"
                                class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-secondary text-muted hover:text-foreground transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                                </svg>
                              </button>
                              <div class="flex items-center gap-1" style="order:2">
                                <button type="button" x-on:click="view = 'months'"
                                  class="font-bold text-sm text-foreground hover:text-primary transition-colors px-1 rounded"
                                  x-text="monthNames[curMonth - 1]"></button>
                                <button type="button" x-on:click="switchToYears()"
                                  class="font-bold text-sm text-foreground hover:text-primary transition-colors px-1 rounded"
                                  x-text="toFa(curYear)"></button>
                              </div>
                              <button type="button" x-on:click="nextMonth()" style="order:3"
                                class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-secondary text-muted hover:text-foreground transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                                </svg>
                              </button>
                            </div>
                            <div style="display:grid;grid-template-columns:repeat(7,1fr);margin-bottom:4px;padding-bottom:8px;border-bottom:1px solid hsl(var(--border))">
                              <div class="text-primary" style="text-align:center;font-size:11px;font-weight:700;padding:4px 0">ش</div>
                              <div class="text-muted"  style="text-align:center;font-size:11px;font-weight:700;padding:4px 0">ی</div>
                              <div class="text-muted"  style="text-align:center;font-size:11px;font-weight:700;padding:4px 0">د</div>
                              <div class="text-muted"  style="text-align:center;font-size:11px;font-weight:700;padding:4px 0">س</div>
                              <div class="text-muted"  style="text-align:center;font-size:11px;font-weight:700;padding:4px 0">چ</div>
                              <div class="text-muted"  style="text-align:center;font-size:11px;font-weight:700;padding:4px 0">پ</div>
                              <div class="text-primary" style="text-align:center;font-size:11px;font-weight:700;padding:4px 0">ج</div>
                            </div>
                            <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-top:4px">
                              <template x-for="(cell, idx) in cells" :key="idx">
                                <div style="display:flex;align-items:center;justify-content:center">
                                  <template x-if="cell !== null">
                                    <button type="button" x-on:click="pick(cell)"
                                      x-bind:class="selYear === curYear && selMonth === curMonth && selDay === cell
                                        ? 'bg-primary text-white font-bold'
                                        : 'text-foreground hover:bg-secondary'"
                                      class="rounded-full text-xs font-medium flex items-center justify-center transition-colors"
                                      style="width:32px;height:32px"
                                      x-text="toFa(cell)"></button>
                                  </template>
                                </div>
                              </template>
                            </div>
                          </div>

                          <!-- ═══ view: months ═══ -->
                          <div x-show="view === 'months'">
                            <div class="flex items-center justify-between mb-4">
                              <button type="button" x-on:click="curYear--" style="order:1"
                                class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-secondary text-muted hover:text-foreground transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                                </svg>
                              </button>
                              <button type="button" x-on:click="switchToYears()" style="order:2"
                                class="font-bold text-sm text-foreground hover:text-primary transition-colors"
                                x-text="toFa(curYear)"></button>
                              <button type="button" x-on:click="curYear++" style="order:3"
                                class="w-8 h-8 flex items-center justify-center rounded-lg hover:bg-secondary text-muted hover:text-foreground transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                                </svg>
                              </button>
                            </div>
                            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px">
                              <template x-for="(mn, mi) in monthNames" :key="mi">
                                <button type="button" x-on:click="pickMonth(mi + 1)"
                                  x-bind:class="curMonth === mi + 1 ? 'bg-primary text-white' : 'text-foreground hover:bg-secondary'"
                                  class="rounded-xl text-xs font-semibold py-2 transition-colors text-center"
                                  x-text="mn"></button>
                              </template>
                            </div>
                          </div>

                          <!-- ═══ view: years ═══ -->
                          <div x-show="view === 'years'">
                            <div class="font-bold text-sm text-foreground text-center mb-3">انتخاب سال</div>
                            <div x-ref="yearList" style="max-height:232px;overflow-y:auto;display:grid;grid-template-columns:repeat(3,1fr);gap:4px">
                              <template x-for="y in yearRange" :key="y">
                                <button type="button" x-on:click="pickYear(y)"
                                  x-bind:data-year="y"
                                  x-bind:class="curYear === y ? 'bg-primary text-white' : 'text-foreground hover:bg-secondary'"
                                  class="rounded-xl text-xs font-semibold py-2 transition-colors text-center"
                                  x-text="toFa(y)"></button>
                              </template>
                            </div>
                          </div>

                        </div>
                      </div>
                    </div>
                    <div class="space-y-1">
                      <label for="bio" class="font-medium text-xs text-muted">درباره من</label>
                      <textarea rows="5" id="bio" x-model="bio"
                        class="form-textarea w-full !ring-0 !ring-offset-0 bg-secondary border-border focus:border-border rounded-xl text-sm text-foreground px-5"></textarea>
                    </div>
                    <div class="flex justify-end gap-5">
                      <button type="submit" x-bind:disabled="loading"
                        class="h-11 inline-flex items-center justify-center gap-3 bg-primary rounded-full text-white px-4 mr-auto disabled:opacity-60">
                        <span class="font-semibold text-sm" x-text="loading ? 'در حال بروزرسانی...' : 'بروزرسانی'"></span>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                          <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 0 1-9.201 2.466l-.312-.311h2.433a.75.75 0 0 0 0-1.5H3.989a.75.75 0 0 0-.75.75v4.242a.75.75 0 0 0 1.5 0v-2.43l.31.31a7 7 0 0 0 11.712-3.138.75.75 0 0 0-1.449-.39Zm1.23-3.723a.75.75 0 0 0 .219-.53V2.929a.75.75 0 0 0-1.5 0V5.36l-.31-.31A7 7 0 0 0 3.239 8.188a.75.75 0 1 0 1.448.389A5.5 5.5 0 0 1 13.89 6.11l.311.31h-2.432a.75.75 0 0 0 0 1.5h4.243a.75.75 0 0 0 .53-.219Z" clip-rule="evenodd" />
                        </svg>
                      </button>
                    </div>
                  </form>
                </div><!-- end tabs:contents:tabOne -->

                <!-- tabs:contents:tabTwo -->
                <div class="space-y-5" x-show="activeTab === 'tabTwo'" x-data="phoneChangeData()">
                  <div class="flex items-center gap-3">
                    <div class="flex items-center gap-1">
                      <div class="w-1 h-1 bg-foreground rounded-full"></div>
                      <div class="w-2 h-2 bg-foreground rounded-full"></div>
                    </div>
                    <div class="font-black text-foreground">شماره موبایل</div>
                  </div>

                  <!-- alert -->
                  <div class="flex items-start gap-3 relative bg-zinc-50 dark:bg-zinc-900 border border-border rounded-xl p-5"
                    x-show="alertOpen" x-data="{ alertOpen: true }">
                    <span class="text-blue-500">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                      </svg>
                    </span>
                    <div class="flex flex-col items-start">
                      <div class="font-bold text-sm text-blue-500 mb-2">توجه :‌</div>
                      <div class="font-semibold text-xs text-zinc-400">
                        <p class="mb-3">شماره تلفن شما برای کارهای مختلفی در سایت مورد استفاده قرار میگیرد با وارد کردن شماره تلفن خود و فعال کردن آن میتوانید بخشی از فعالیت های خود را در لیان امیری سریع تر انجام دهید.</p>
                        <ul>
                          <li>۱.ورود به سایت تماما با شماره تلفن همراه انجام خواهد شد.</li>
                          <li>۲.در هنگام ورود به سایت پیامکی برای شما ارسال میشود تا از ورود‌های بدون اجازه مطلع شوید.</li>
                        </ul>
                      </div>
                      <div class="flex flex-wrap items-center gap-3 mt-5">
                        <button type="button"
                          class="flex items-center gap-x-1 text-zinc-400 underline-offset-1 hover:underline"
                          x-on:click="alertOpen = false">
                          <span class="font-bold text-xs">فهمیدم</span>
                        </button>
                      </div>
                    </div>
                  </div><!-- end alert -->

                  <!-- step 1: enter new phone number -->
                  <div x-show="step === 1" class="space-y-5">
                    <div class="flex flex-col gap-5">
                      <div class="space-y-1 sm:w-1/2">
                        <label class="block font-medium text-xs text-muted">شماره تماس فعلی</label>
                        <input type="text" dir="ltr"
                          class="form-input w-full h-11 !ring-0 !ring-offset-0 bg-secondary border-border focus:border-border rounded-xl text-sm text-foreground disabled:text-muted px-5"
                          x-bind:value="currentPhone" disabled />
                      </div>
                      <div class="space-y-1 sm:w-1/2">
                        <label for="new_phone" class="block font-medium text-xs text-muted">شماره تماس جدید</label>
                        <input type="text" dir="ltr" id="new_phone" placeholder="09xxxxxxxxx"
                          x-model="newPhone"
                          x-on:input="newPhone = normalizeDigits($event.target.value)"
                          class="form-input w-full h-11 !ring-0 !ring-offset-0 bg-secondary border-border focus:border-border rounded-xl text-sm text-foreground px-5" />
                      </div>
                    </div>
                    <div class="flex justify-end">
                      <button type="button" x-on:click="requestOtp()" x-bind:disabled="loading"
                        class="h-11 inline-flex items-center justify-center gap-3 bg-primary rounded-full text-white px-4 disabled:opacity-60">
                        <span class="font-semibold text-sm" x-text="loading ? 'در حال ارسال...' : 'ارسال کد تایید'"></span>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                          <path d="M3.105 2.289a.75.75 0 00-.826.95l1.414 4.925A1.5 1.5 0 005.135 9.25h6.115a.75.75 0 010 1.5H5.135a1.5 1.5 0 00-1.442 1.086l-1.414 4.926a.75.75 0 00.826.95 28.896 28.896 0 0015.293-7.154.75.75 0 000-1.115A28.897 28.897 0 003.105 2.289z" />
                        </svg>
                      </button>
                    </div>
                  </div>

                  <!-- step 2: verify OTP -->
                  <div x-show="step === 2" class="space-y-5">
                    <div class="space-y-1 sm:w-1/2">
                      <label for="otp_code" class="block font-medium text-xs text-muted">کد تایید</label>
                      <input type="text" dir="ltr" id="otp_code" maxlength="8" autocomplete="one-time-code"
                        x-model="code"
                        x-on:input="code = normalizeDigits($event.target.value)"
                        class="form-input w-full h-11 !ring-0 !ring-offset-0 bg-secondary border-border focus:border-border rounded-xl text-sm text-foreground px-5" />
                    </div>
                    <div class="flex items-center justify-between gap-5">
                      <button type="button" x-on:click="step = 1"
                        class="h-11 inline-flex items-center justify-center gap-2 border border-border rounded-full text-muted px-4 text-sm font-semibold hover:text-foreground transition-colors">
                        انصراف
                      </button>
                      <button type="button" x-on:click="verifyOtp()" x-bind:disabled="loading"
                        class="h-11 inline-flex items-center justify-center gap-3 bg-primary rounded-full text-white px-4 disabled:opacity-60">
                        <span class="font-semibold text-sm" x-text="loading ? 'در حال تایید...' : 'تایید شماره'"></span>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                        </svg>
                      </button>
                    </div>
                  </div>

                </div><!-- end tabs:contents:tabTwo -->
              </div><!-- end tabs:contents -->
            </div><!-- end tabs container -->
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
function jalaliPicker(initial) {
  function _d(a, b) { return Math.trunc(a / b); }
  function _m(a, b) { return a - Math.trunc(a / b) * b; }

  function jalCal(jy) {
    var br = [-61,9,38,199,426,686,756,818,1111,1181,1210,1635,2060,2097,2192,2262,2324,2394,2456,3178];
    var gy = jy + 621, lj = -14, jp = br[0], jm, jump, lg, march, leap, n;
    for (var i = 1; i < br.length; i++) {
      jm = br[i]; jump = jm - jp;
      if (jy < jm) break;
      lj += _d(jump, 33) * 8 + _d(_m(jump, 33), 4);
      jp = jm;
    }
    n = jy - jp;
    lj += _d(n, 33) * 8 + _d(_m(n, 33) + 3, 4);
    if (_m(jump, 33) === 4 && jump - n === 4) lj++;
    lg = _d(gy, 4) - _d((_d(gy, 100) + 1) * 3, 4) - 150;
    march = 20 + lj - lg;
    if (jump - n < 6) n = n - jump + _d(jump + 4, 33) * 33;
    leap = _m(_m(n + 1, 33) - 1, 4);
    return { leap: leap === -1 ? 4 : leap, gy: gy, march: march };
  }

  function g2d(gy, gm, gd) {
    var d = _d((gy + _d(gm - 8, 6) + 100100) * 1461, 4) + _d(153 * _m(gm + 9, 12) + 2, 5) + gd - 34840408;
    return d - _d(_d(gy + 100100 + _d(gm - 8, 6), 100) * 3, 4) + 752;
  }

  function j2d(jy, jm, jd) {
    var r = jalCal(jy);
    return g2d(r.gy, 3, r.march) + (jm - 1) * 30 + Math.min(jm, 7) - 1 + jd - 1;
  }

  function monthLen(jy, jm) {
    if (jm <= 6) return 31;
    if (jm <= 11) return 30;
    return jalCal(jy).leap === 0 ? 30 : 29;
  }

  // returns 0=Sat … 6=Fri (matches RTL grid column order)
  function startOffset(jy, jm) {
    return _m(j2d(jy, jm, 1) + 2, 7);
  }

  var sy = null, sm = null, sd = null;
  if (initial && /^\d{4}\/\d{1,2}\/\d{1,2}$/.test(initial)) {
    var p = initial.split('/');
    sy = +p[0]; sm = +p[1]; sd = +p[2];
  }

  var yrs = [];
  for (var y = 1300; y <= 1415; y++) yrs.push(y);

  return {
    open: false,
    view: 'cal',
    curYear:   sy || 1403,
    curMonth:  sm || 7,
    selYear:   sy,
    selMonth:  sm,
    selDay:    sd,
    cells: [],
    monthNames: ['فروردین','اردیبهشت','خرداد','تیر','مرداد','شهریور','مهر','آبان','آذر','دی','بهمن','اسفند'],
    yearRange: yrs,

    toFa(n) {
      return String(n).replace(/\d/g, function(d) { return '۰۱۲۳۴۵۶۷۸۹'[d]; });
    },

    build() {
      var offset = startOffset(this.curYear, this.curMonth);
      var days   = monthLen(this.curYear, this.curMonth);
      var arr = [];
      for (var i = 0; i < offset; i++) arr.push(null);
      for (var d = 1; d <= days; d++) arr.push(d);
      this.cells = arr;
    },

    toggle() {
      this.open = !this.open;
      if (this.open) this.view = 'cal';
    },

    switchToYears() {
      this.view = 'years';
      var self = this;
      this.$nextTick(function() {
        var list = self.$refs.yearList;
        if (!list) return;
        var btn = list.querySelector('[data-year="' + self.curYear + '"]');
        if (btn) btn.scrollIntoView({ block: 'center' });
      });
    },

    pickMonth(m) {
      this.curMonth = m;
      this.build();
      this.view = 'cal';
    },

    pickYear(y) {
      this.curYear = y;
      this.view = 'months';
    },

    get value() {
      if (!this.selYear) return '';
      return this.selYear + '/' + String(this.selMonth).padStart(2,'0') + '/' + String(this.selDay).padStart(2,'0');
    },
    get display() {
      if (!this.selYear) return '';
      return this.toFa(this.selYear) + ' ' + this.monthNames[this.selMonth - 1] + ' ' + this.toFa(this.selDay);
    },

    pick(d) {
      this.selYear = this.curYear; this.selMonth = this.curMonth; this.selDay = d;
      this.open = false;
    },
    prevMonth() {
      if (this.curMonth === 1) { this.curMonth = 12; this.curYear--; }
      else this.curMonth--;
      this.build();
    },
    nextMonth() {
      if (this.curMonth === 12) { this.curMonth = 1; this.curYear++; }
      else this.curMonth++;
      this.build();
    },
  };
}

function profileInfoData() {
  return {
    loading: false,
    displayName: <%- JSON.stringify(user.displayName || '') %>,
    bio: <%- JSON.stringify(user.bio || '') %>,

    async submit() {
      this.loading = true;
      try {
        const birthday = this.$el.querySelector('[name="birthday"]')?.value ?? '';
        const res = await fetch('/api/profile/info', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ displayName: this.displayName, birthday, bio: this.bio }),
        });
        const data = await res.json();
        if (res.ok) {
          showAlert(data.message || 'اطلاعات با موفقیت بروزرسانی شد.', 'success');
        } else {
          showAlert(Array.isArray(data.message) ? data.message.join(' ') : (data.message || 'خطایی رخ داد'), 'error');
        }
      } catch {
        showAlert('خطا در ارتباط با سرور', 'error');
      } finally {
        this.loading = false;
      }
    },
  };
}

function phoneChangeData() {
  return {
    step: 1,
    loading: false,
    newPhone: '',
    code: '',
    masked: '',
    currentPhone: '<%= user.phone || "" %>',
    normalizeDigits(val) {
      return val
        .replace(/[۰-۹]/g, d => String(d.charCodeAt(0) - 0x06F0))
        .replace(/[٠-٩]/g, d => String(d.charCodeAt(0) - 0x0660));
    },
    async requestOtp() {
      this.loading = true;
      try {
        const res = await fetch('/api/profile/phone/request', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ phone: this.newPhone }),
        });
        const data = await res.json();
        if (res.ok) {
          this.masked = data.masked;
          this.step = 2;
          showAlert(`کد با موفقیت به شماره ${this.newPhone} ارسال شد` , 'success')
        } else {
          showAlert(Array.isArray(data.message) ? data.message.join(' ') : (data.message || 'خطایی رخ داد'), 'error');
        }
      } catch {
        showAlert('خطا در ارتباط با سرور', 'error');
      } finally {
        this.loading = false;
      }
    },
    async verifyOtp() {
      this.loading = true;
      try {
        const res = await fetch('/api/profile/phone/verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ code: this.code }),
        });
        const data = await res.json();
        if (res.ok) {
          this.currentPhone = data.phone;
          this.newPhone = '';
          this.code = '';
          this.step = 1;
          showAlert('شماره موبایل با موفقیت تغییر یافت.', 'success');
        } else {
          showAlert(Array.isArray(data.message) ? data.message.join(' ') : (data.message || 'خطایی رخ داد'), 'error');
        }
      } catch {
        showAlert('خطا در ارتباط با سرور', 'error');
      } finally {
        this.loading = false;
      }
    },
  };
}
</script>
