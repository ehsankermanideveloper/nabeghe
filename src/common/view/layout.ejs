<!DOCTYPE html>
<html lang="fa" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%
      const _siteName  = 'بنیاد لیان امیری';
      const _title     = (typeof pageTitle     !== 'undefined' && pageTitle)     ? pageTitle     : _siteName;
      const _desc      = (typeof seoDescription!== 'undefined' && seoDescription)? seoDescription: 'بنیاد لیان امیری در سال ۱۳۹۴ با هدف ارتقاء سطح دانش و با شعار «دانش اساس تکامل بشر» تأسیس شد. دوره‌های آموزشی رایگان برای افراد محروم.';
      const _robots    = (typeof seoRobots     !== 'undefined' && seoRobots)     ? seoRobots     : 'index, follow';
      const _canonical = (typeof seoCanonical  !== 'undefined' && seoCanonical)  ? seoCanonical  : null;
      const _ogType    = (typeof ogType        !== 'undefined' && ogType)        ? ogType        : 'website';
      const _ogImage   = (typeof ogImage       !== 'undefined' && ogImage)       ? ogImage       : null;
      const _jsonLd    = (typeof jsonLd        !== 'undefined' && jsonLd)        ? jsonLd        : null;
      const _keywords  = (typeof seoKeywords   !== 'undefined' && seoKeywords)   ? seoKeywords   : 'بنیاد لیان امیری, آموزش, دوره آموزشی, مقاله';
    %>

    <title><%= _title %></title>

    <!-- Primary Meta -->
    <meta name="description" content="<%= _desc %>" />
    <meta name="keywords" content="<%= _keywords %>" />
    <meta name="robots" content="<%= _robots %>" />
    <meta name="author" content="<%= _siteName %>" />
    <meta name="theme-color" content="#0f172a" />
    <% if (_canonical) { %>
    <link rel="canonical" href="<%= _canonical %>" />
    <% } %>

    <!-- Open Graph -->
    <meta property="og:site_name"   content="<%= _siteName %>" />
    <meta property="og:type"        content="<%= _ogType %>" />
    <meta property="og:title"       content="<%= _title %>" />
    <meta property="og:description" content="<%= _desc %>" />
    <meta property="og:locale"      content="fa_IR" />
    <% if (_canonical) { %>
    <meta property="og:url" content="<%= _canonical %>" />
    <% } %>
    <% if (_ogImage) { %>
    <meta property="og:image"       content="<%= _ogImage %>" />
    <meta property="og:image:alt"   content="<%= _title %>" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <% } %>

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content="<%= _title %>" />
    <meta name="twitter:description" content="<%= _desc %>" />
    <% if (_ogImage) { %>
    <meta name="twitter:image" content="<%= _ogImage %>" />
    <% } %>

    <!-- JSON-LD Structured Data -->
    <% if (_jsonLd) { %>
    <script type="application/ld+json"><%- _jsonLd %></script>
    <% } %>

    <!-- Preload critical fonts -->
    <link rel="preload" href="/assets/fonts/yekanBakh/woff2/YekanBakhFaNum-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/assets/fonts/yekanBakh/woff2/YekanBakhFaNum-Bold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/assets/fonts/yekanBakh/woff2/YekanBakhFaNum-SemiBold.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Assets -->
    <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg" />
    <% if (locals.useSwiper) { %>
    <link rel="stylesheet" href="/assets/css/dependencies/swiper-bundle.min.css" />
    <% } %>
    <% if (locals.usePlyr) { %>
    <link rel="stylesheet" href="/assets/css/dependencies/plyr.min.css" />
    <% } %>
    <link rel="stylesheet" href="/assets/css/fonts.css" />
    <link rel="stylesheet" href="/assets/css/app.css" />

    <!-- Dark mode: must run before body paint to prevent flash -->
    <script>(function(){if(localStorage.getItem('darkMode')!=='false')document.documentElement.classList.add('dark');}());</script>

    <style>
      [x-cloak] { display: none !important; }
      @keyframes img-shimmer {
        0% { background-position: 200% center; }
        100% { background-position: -200% center; }
      }
      [data-skeleton] {
        background: linear-gradient(
          90deg,
          var(--color-secondary, #1e1e2e) 25%,
          color-mix(in srgb, var(--color-secondary, #1e1e2e) 60%, white) 50%,
          var(--color-secondary, #1e1e2e) 75%
        );
        background-size: 200% 100%;
        animation: img-shimmer 1.8s ease-in-out infinite;
      }
    </style>
  </head>
  <body>
    <div class="flex flex-col min-h-screen bg-background">
      <%- include('partials/header') %>
      <%- body %>
      <%- include('partials/footer') %>
    </div>

    <script src="/assets/js/img-skeleton.js" defer></script>
    <script src="/assets/js/dependencies/alpinejs.min.js" defer></script>
    <% if (locals.useSwiper) { %>
    <script src="/assets/js/dependencies/swiper-bundle.min.js" defer></script>
    <script src="/assets/js/swiper-init.js" defer></script>
    <% } %>
    <% if (locals.usePlyr) { %>
    <script src="/assets/js/dependencies/plyr.min.js" defer></script>
    <script defer>document.addEventListener('DOMContentLoaded',function(){document.querySelectorAll('.js-player').forEach(function(p){new Plyr(p);});});</script>
    <% } %>
    <script src="/assets/js/app.js" defer></script>
  </body>
</html>
