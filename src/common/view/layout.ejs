<!DOCTYPE html>
<html lang="<%= typeof locale !== 'undefined' ? locale : 'fa' %>" dir="<%= typeof dir !== 'undefined' ? dir : 'rtl' %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%
      const _siteName  = t('site_name');
      const _title     = (typeof pageTitle     !== 'undefined' && pageTitle)     ? pageTitle     : _siteName;
      const _desc      = (typeof seoDescription!== 'undefined' && seoDescription)? seoDescription: t('site_seo_desc');
      const _robots    = (typeof seoRobots     !== 'undefined' && seoRobots)     ? seoRobots     : 'noindex, nofollow';
      const _canonical = (typeof seoCanonical  !== 'undefined' && seoCanonical)  ? seoCanonical  : null;
      const _ogType    = (typeof ogType        !== 'undefined' && ogType)        ? ogType        : 'website';
      const _ogImage   = (typeof ogImage       !== 'undefined' && ogImage)       ? ogImage       : null;
      const _jsonLd    = (typeof jsonLd        !== 'undefined' && jsonLd)        ? jsonLd        : null;
      const _keywords  = (typeof seoKeywords   !== 'undefined' && seoKeywords)   ? seoKeywords   : t('site_seo_keywords');
    %>

    <title><%= _title %></title>

    <!-- Primary Meta -->
    <meta name="description" content="<%= _desc %>" />
    <meta name="keywords" content="<%= _keywords %>" />
    <meta name="robots" content="<%= _robots %>" />
    <meta name="author" content="<%= _siteName %>" />
    <meta name="theme-color" content="#0f172a" />
    <% if (_canonical) { %>
    <link rel="canonical" href="<%= _canonical %>" />
    <% } %>

    <!-- Open Graph -->
    <meta property="og:site_name"   content="<%= _siteName %>" />
    <meta property="og:type"        content="<%= _ogType %>" />
    <meta property="og:title"       content="<%= _title %>" />
    <meta property="og:description" content="<%= _desc %>" />
    <meta property="og:locale"      content="<%= typeof locale !== 'undefined' && locale === 'en' ? 'en_US' : locale === 'ps' ? 'ps_AF' : 'fa_IR' %>" />
    <% if (_canonical) { %>
    <meta property="og:url" content="<%= _canonical %>" />
    <% } %>
    <% if (_ogImage) { %>
    <meta property="og:image"       content="<%= _ogImage %>" />
    <meta property="og:image:alt"   content="<%= _title %>" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <% } %>

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content="<%= _title %>" />
    <meta name="twitter:description" content="<%= _desc %>" />
    <% if (_ogImage) { %>
    <meta name="twitter:image" content="<%= _ogImage %>" />
    <% } %>

    <!-- JSON-LD Structured Data -->
    <% if (_jsonLd) { %>
    <script type="application/ld+json"><%- _jsonLd %></script>
    <% } %>

    <!-- Preconnect to external video/asset origins -->
    <link rel="preconnect" href="https://assets.mediadelivery.net" crossorigin />
    <link rel="dns-prefetch" href="https://b-cdn.net" />

    <!-- Preload critical fonts (Regular + SemiBold cover body + headings; Bold loaded lazily) -->
    <link rel="preload" href="/assets/fonts/yekanBakh/woff2/YekanBakhFaNum-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/assets/fonts/yekanBakh/woff2/YekanBakhFaNum-SemiBold.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Assets -->
    <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg" />
    <% if (locals.useSwiper) { %>
    <link rel="stylesheet" href="/assets/css/dependencies/swiper-bundle.min.css?v=<%= assetVersion %>" />
    <% } %>
    <% if (locals.usePlyr) { %>
    <link rel="stylesheet" href="/assets/css/dependencies/plyr.min.css?v=<%= assetVersion %>" />
    <% } %>
    <link rel="stylesheet" href="/assets/css/fonts.css?v=<%= assetVersion %>" />
    <link rel="stylesheet" href="/assets/css/app.css?v=<%= assetVersion %>" />

    <!-- Dark mode: must run before body paint to prevent flash -->
    <script>(function(){if(localStorage.getItem('darkMode')!=='false')document.documentElement.classList.add('dark');}());</script>

    <style>
      [x-cloak] { display: none !important; }
      @keyframes img-shimmer {
        0% { background-position: 200% center; }
        100% { background-position: -200% center; }
      }
      [data-skeleton] {
        background: linear-gradient(
          90deg,
          var(--color-secondary, #1e1e2e) 25%,
          color-mix(in srgb, var(--color-secondary, #1e1e2e) 60%, white) 50%,
          var(--color-secondary, #1e1e2e) 75%
        );
        background-size: 200% 100%;
        animation: img-shimmer 1.8s ease-in-out infinite;
      }
    </style>
  </head>
  <body>
    <div class="flex flex-col min-h-screen bg-background">
      <%- include('partials/header') %>
      <%- body %>
      <%- include('partials/footer') %>
    </div>

    <script src="/assets/js/img-skeleton.js?v=<%= assetVersion %>" defer></script>
    <script src="/assets/js/dependencies/alpinejs.min.js?v=<%= assetVersion %>" defer></script>
    <% if (locals.useSwiper) { %>
    <script src="/assets/js/dependencies/swiper-bundle.min.js?v=<%= assetVersion %>" defer></script>
    <script src="/assets/js/swiper-init.js?v=<%= assetVersion %>" defer></script>
    <% } %>
    <% if (locals.useHls) { %>
    <script src="/assets/js/dependencies/hls.min.js?v=<%= assetVersion %>" defer></script>
    <% } %>
    <% if (locals.usePlyr) { %>
    <script src="/assets/js/dependencies/plyr.min.js?v=<%= assetVersion %>" defer onload="document.querySelectorAll('.js-player').forEach(function(p){new Plyr(p);})"></script>
    <% } %>
    <script>window._lp="<%= lp %>";window._i18n={msg_wishlist_login_required:"<%- t('msg_wishlist_login_required') %>",msg_error_generic:"<%- t('msg_error_generic') %>",msg_error_server:"<%- t('msg_error_server') %>"};</script>
    <script src="/assets/js/app.js?v=<%= assetVersion %>" defer></script>

    <% if (typeof flash !== 'undefined' && flash) { %>
    <div id="__toast" style="position:fixed;bottom:1.5rem;<%= dir === 'ltr' ? 'right' : 'left' %>:1.5rem;z-index:9999;display:flex;align-items:center;gap:0.75rem;background:var(--color-background,#0f172a);border:1px solid var(--color-border,#334155);border-radius:1rem;padding:0.75rem 1rem;max-width:22rem;box-shadow:0 8px 24px rgba(0,0,0,.35);opacity:0;transform:translateY(1rem);transition:opacity .3s ease,transform .3s ease;">
      <span style="flex-shrink:0;display:flex;align-items:center;justify-content:center;width:2rem;height:2rem;border-radius:9999px;background:rgba(34,197,94,.15);color:#22c55e;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="18" height="18">
          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd"/>
        </svg>
      </span>
      <p style="flex:1;font-size:.875rem;font-weight:600;color:var(--color-foreground,#f1f5f9);margin:0;"><%= t(flash.messageKey) %></p>
      <button id="__toast_close" style="flex-shrink:0;color:var(--color-muted,#64748b);background:none;border:none;cursor:pointer;line-height:0;padding:0;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
          <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z"/>
        </svg>
      </button>
    </div>
    <script>
      (function(){
        var t=document.getElementById('__toast');
        if(!t)return;
        requestAnimationFrame(function(){
          requestAnimationFrame(function(){
            t.style.opacity='1';t.style.transform='translateY(0)';
          });
        });
        function hide(){t.style.opacity='0';t.style.transform='translateY(1rem)';setTimeout(function(){t.remove();},300);}
        setTimeout(hide,4500);
        document.getElementById('__toast_close').addEventListener('click',hide);
      })();
    </script>
    <% } %>
  </body>
</html>
