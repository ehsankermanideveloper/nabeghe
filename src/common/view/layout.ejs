<!DOCTYPE html>
<html lang="fa" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg" />
    <link rel="stylesheet" href="/assets/css/dependencies/swiper-bundle.min.css" />
    <link rel="stylesheet" href="/assets/css/dependencies/plyr.min.css" />
    <link rel="stylesheet" href="/assets/css/fonts.css" />
    <link rel="stylesheet" href="/assets/css/app.css" />
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'آکادمی لیان امیری' %></title>
    <style>
      [x-cloak] { display: none !important; }
      @keyframes img-shimmer {
        0% { background-position: 200% center; }
        100% { background-position: -200% center; }
      }
      [data-skeleton] {
        background: linear-gradient(
          90deg,
          var(--color-secondary, #1e1e2e) 25%,
          color-mix(in srgb, var(--color-secondary, #1e1e2e) 60%, white) 50%,
          var(--color-secondary, #1e1e2e) 75%
        );
        background-size: 200% 100%;
        animation: img-shimmer 1.8s ease-in-out infinite;
      }
    </style>
  </head>
  <body>
    <div class="flex flex-col min-h-screen bg-background">
      <%- include('partials/header') %>
      <%- body %>
      <%- include('partials/footer') %>
    </div>

    <script src="/assets/js/img-skeleton.js"></script>
    <script src="/assets/js/dependencies/alpinejs.min.js"></script>
    <script src="/assets/js/dependencies/swiper-bundle.min.js"></script>
    <script src="/assets/js/dependencies/plyr.min.js"></script>
    <script src="/assets/js/app.js"></script>
  </body>
</html>
