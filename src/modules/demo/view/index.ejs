<main class="flex-auto py-5">
  <div class="max-w-7xl space-y-8 px-4 mx-auto">
    <h1 class="font-bold text-xl text-foreground"><%= title %></h1>
    <p class="font-semibold text-sm text-muted">
      Rendered with <strong>EJS</strong> and the shared layout (header / footer).
      Data from <strong>TypeORM</strong>.
    </p>
    <% if (!items?.length) { %>
      <p class="text-sm text-muted">No rows yet.</p>
    <% } else { %>
      <ul class="space-y-3">
        <% items.forEach(function (row) { %>
          <li class="p-4 bg-secondary rounded-xl">
            <strong class="text-foreground"><%= row.title %></strong><br />
            <small class="text-muted">id: <%= row.id %> — created: <%= row.createdAt %></small>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </div>
</main>
